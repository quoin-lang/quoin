runner = TestRunner.new;

testFolder = ([IO]Folder.open:'bblib/tests');
(testFolder
    .list
    .sort:{|sf| (sf.name.split:'-').first.to_integer})
    .each:{|ef|
    (ef.is_file? && (ef.ext == 'bub')).if:{
        [IO]Stdout.writeln:'Loading ' + ef.name + '...';
        suite = Runtime.evalFile:ef.fullpath;
        runner.add:suite;
    }
};

runner.add:Runtime.evalFile:'bblib/tests/01-iterate.bub';

results = runner.run:AnsiTestReporter.new:{ out = [IO]Stdout }

results.none?:{|tr| tr.failures.any? }
