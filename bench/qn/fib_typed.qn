"Typed recursive Fibonacci - exercises the typed/devirt hot path
(sealed Integer arithmetic, typed params and return, inlined control flow).
Run whole-process: `qn bench/qn/fib_typed.qn` from the repo root."

Fib <- {
    .meta <-- {
        value: -> { |n: Integer ^Integer|
            (n <= 1).if:{ ^n } else:{ ^(.value:(n - 1)) + (.value:(n - 2)) }
        }
    };
    .sealed!
}

var r = Fib.value:32
(r == 2178309).if:{ 'fib_typed: ok'.print } else:{ ('fib_typed: FAIL got ' + r).print }
