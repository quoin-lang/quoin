"* base64 / hex codecs (src/runtime/codecs.rs) and the Bytes/String convenience helpers
"* (qnlib/core/09-codecs.qn).

(TestSuite.new:{ name = 'Codecs' }).add:{
    .test:
    base64 -> {
        .is:{ Base64.encode:'hello'.asBytes } equalTo:'aGVsbG8=';
        .is:{ (Base64.decode:'aGVsbG8=').asString } equalTo:'hello';
        .does:{ Base64.decode:'!!!' } throw:ValueError;
        "* round-trips arbitrary bytes
        .is:{ (Base64.decode:(Base64.encode:'any data 123'.asBytes)).asString }
            equalTo:'any data 123';
    };

    .test:
    hex -> {
        .is:{ Hex.encode:'hi'.asBytes } equalTo:'6869';
        .is:{ (Hex.decode:'6869').asString } equalTo:'hi';
        "* decode is case-insensitive
        .is:{ (Hex.decode:'48454C4C4F').asString } equalTo:'HELLO';
        .does:{ Hex.decode:'zz' } throw:ValueError;
    };

    .test:
    helpers -> {
        .is:{ 'hello'.asBytes.toBase64 } equalTo:'aGVsbG8=';
        .is:{ 'hi'.asBytes.toHex } equalTo:'6869';
        .is:{ 'hello'.toBase64 } equalTo:'aGVsbG8=';       "* encodes the String's UTF-8
        .is:{ 'aGVsbG8='.fromBase64.asString } equalTo:'hello';
        .is:{ '6869'.fromHex.asString } equalTo:'hi';
        .is:{ 'round trip!'.toBase64.fromBase64.asString } equalTo:'round trip!';
    };
};
