"* Coverage for the List native class (src/runtime/list.rs), driven through the #(...)
"* literal. Focuses on the arms the incidental list usage elsewhere doesn't reach:
"* out-of-bounds at:, sliceFrom: past the end, ==: mismatches, bind:, and both sort:
"* branches (a 1-arg key block and a 2-arg comparator block).

(TestSuite.new:{ var name = 'List' }).add:{
    .test:
    atOutOfBoundsIsNil -> {
        .is:{ #(1 2 3).at:0 } equalTo:1;
        .is:{ #(1 2 3).at:9 } equalTo:nil;          "* past the end -> nil
        .is:{ #(1 2 3).at:-1 } equalTo:nil;         "* negative -> nil
    };

    .test:
    sliceFrom -> {
        .is:{ #(1 2 3 4).sliceFrom:2 } equalTo:#( 3 4 );
        .is:{ #(1 2 3).sliceFrom:9 } equalTo:#( );   "* start past the end -> empty
        .is:{ #(1 2 3).sliceFrom:0 } equalTo:#( 1 2 3 );
    };

    .test:
    equality -> {
        .isTrue:{ #(1 2 3) == #(1 2 3) };
        .isFalse:{ #(1 2) == #(1 2 3) };             "* length mismatch
        .isFalse:{ #(1 2 3) == #(1 9 3) };           "* element differs
        .isFalse:{ #(1 2) == 5 };                    "* rhs is not a List
    };

    .test:
    bind -> {
        "* bind: feeds the first N elements (N = block arity) as the block's args
        .is:{ #(10 20).bind:{ |a b| a + b } } equalTo:30;
        .is:{ #(7 8 9).bind:{ |a| a } } equalTo:7;
    };

    .test:
    sortWithKeyBlock -> {
        "* sort: with a 1-arg block sorts by the key it returns
        .is:{ #(3 1 2).sort:{ |x| x } } equalTo:#( 1 2 3 );
        .is:{ #('bb' 'a' 'ccc').sort:{ |x| x.length } } equalTo:#( 'a' 'bb' 'ccc' );
        "* nil keys are tolerated (sorted to the end) without calling >: on nil
        .is:{ (#(2 nil 1).sort:{ |x| x }).count } equalTo:3;
    };

    .test:
    sortWithComparatorBlock -> {
        "* sort: with a 2-arg block uses it as a 'comes-before' comparator
        .is:{ #(3 1 2).sort:{ |a b| a < b } } equalTo:#( 1 2 3 );
        .is:{ #(1 2 3).sort:{ |a b| a > b } } equalTo:#( 3 2 1 );
    };

    "* `List.new` constructs a REAL native list (the generic fallback used to
    "* mint a payload-less shell whose first native call errored); `new:` is
    "* refused clearly — a config block is meaningless on a native collection.
    .test:
    classNewConstructs -> {
        var l = List.new;
        l.add:1;
        l.add:{ 5 };
        .is:{ l.count } equalTo:2;
        .is:{ (l.at:1).value } equalTo:5;
        var caught = 'no';
        { List.new:{ a = 1 } }.catch:{ |e| caught = 'yes' };
        .is:{ caught } equalTo:'yes';
    };

    "* List elements are juxtaposed expressions, so an operator that is also a prefix
    "* operator (`+ - %`) is ambiguous. Spacing decides: detached from its left operand and
    "* glued to its right one, it is a prefix that starts a NEW element. Every other spacing
    "* is infix. See `41-list.qn`'s Rust counterpart in crates/quoin-syntax parser_tests.
    .test:
    prefixOperatorsStartNewElements -> {
        "* a list of negative numbers means what it looks like
        .is:{ #(-1 -2).count } equalTo:2;
        .is:{ #(-1 -2).first } equalTo:(0 - 1);
        .is:{ #(-1 -2).second } equalTo:(0 - 2);
        .is:{ #(5 -10).count } equalTo:2;
        .is:{ #(5 -10).second } equalTo:(0 - 10);
        .is:{ #(-3 -1 -2 0 5 -10).count } equalTo:6;
        .is:{ #(-1.5 -2.5).count } equalTo:2;

        "* the other three spacings are all infix subtraction
        .is:{ #(7 - 3) } equalTo:#(4);
        .is:{ #(7-3) } equalTo:#(4);
        .is:{ #(7- 3) } equalTo:#(4);
        .is:{ #(10 - 3 - 2) } equalTo:#(5);

        "* including subtraction from a computed operand
        var x = 5;
        .is:{ #(x.abs-1) } equalTo:#(4);
        .is:{ #((x)-1) } equalTo:#(4);

        "* the prefix binds tighter than the infix after it: (-2) + 3, not -(2 + 3)
        .is:{ #(1 -2 + 3).second } equalTo:1;

        "* identifiers split exactly like numbers
        var a = 9;
        var b = 4;
        .is:{ #(a -b).count } equalTo:2;
        .is:{ #(a -b).second } equalTo:(0 - 4);
        .is:{ #(a - b) } equalTo:#(5);

        "* `+` follows the same rule
        .is:{ #(1 +2).count } equalTo:2;
        .is:{ #(1 + 2) } equalTo:#(3);
        .is:{ #(1+2) } equalTo:#(3);

        "* and so does `%` — glued-right it is the interpolation prefix, else format/modulo
        .is:{ #(10 % 3) } equalTo:#(1);
        .is:{ #(10%3) } equalTo:#(1);
        var v = 'X';
        .is:{ #( 'a' %'b%{v}' ).count } equalTo:2;
        .is:{ #( 'a' %'b%{v}' ).second } equalTo:'bX';
        .is:{ #( 'n=%' % 5 ) } equalTo:#('n=5');

        "* `!` is never infix (the infix form is `!=`), so it needs no rule
        .is:{ #(1 != 2) } equalTo:#(true);
        .is:{ #(true !true).count } equalTo:2
    }

}
