"* YAML (src/runtime/yaml.rs) over the DataValue bridge (serde_yaml_ng). Unlike TOML, YAML allows
"* any top-level value and has a native null.

(TestSuite.new:{ name = 'YAML' }).add:{
    .test:
    parse -> {
        d = YAML.parse:'name: qn\ncount: 3\nratio: 1.5\nok: true';
        .is:{ d.at:'name' } equalTo:'qn';
        .is:{ d.at:'count' } equalTo:3;
        .is:{ d.at:'ratio' } equalTo:1.5;
        .is:{ d.at:'ok' } equalTo:true;
    };

    .test:
    nestedAndLists -> {
        d = YAML.parse:'server:\n  host: localhost\n  port: 8080\ntags:\n  - a\n  - b';
        .is:{ (d.at:'server').at:'host' } equalTo:'localhost';
        .is:{ (d.at:'server').at:'port' } equalTo:8080;
        .is:{ d.at:'tags' } equalTo:#('a' 'b');
    };

    .test:
    topLevelAndNull -> {
        "* YAML (unlike TOML) allows any top-level value, and has a native null.
        .is:{ YAML.parse:'42' } equalTo:42;
        .is:{ YAML.parse:'- 1\n- 2' } equalTo:#(1 2);
        .is:{ YAML.parse:'~' } equalTo:nil;
        .isFalse:{ ((YAML.parse:'x: null').at:'x').defined? };
    };

    .test:
    generate -> {
        "* keys emit sorted; the result re-parses to the same data.
        out = YAML.generate: #{'b': 2 'a': 1};
        .is:{ (YAML.parse:out).at:'a' } equalTo:1;
        .is:{ (YAML.parse:out).at:'b' } equalTo:2;
        "* nil is allowed (YAML has null) and round-trips back to nil.
        .isFalse:{ ((YAML.parse:(YAML.generate: #{'x': nil})).at:'x').defined? };
    };

    .test:
    errors -> {
        .does:{ YAML.parse:': : :\n  - bad' } throw:ParseError;
    };
}
