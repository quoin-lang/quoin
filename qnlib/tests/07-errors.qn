(TestSuite.new:{ var name = 'Errors' }).add:{
    .test:
    throw -> {
        .does:{ 77.throw } throw:77;
        .does:{ Integer.throw } throw:Integer;
        .does:{ 'Hi'.throw } throw:'Hi';
        .does:{ Error.new.throw } throw:Error;
    };

    "* Class-side `throw:` builds and throws an instance of that error type."
    .test:
    typedThrow -> {
        .does:{ TypeError.throw:'nope' } throw:TypeError;
        "* a TypeError is-an Error, so it matches the base type too"
        .does:{ TypeError.throw:'nope' } throw:Error;
    };

    "* Errors carry a message and an optional payload."
    .test:
    errorCarriesMessageAndPayload -> {
        var caught = nil;
        { ArgumentError.throw:'too many' payload:#(1 2 3) }.catch:{ |e| caught = e };
        .is:{ caught.message } equalTo:'too many';
        .is:{ caught.payload } equalTo:#(1 2 3);
        .is:{ caught.class } equalTo:ArgumentError;
    };

    "* Errors are dispatched by type in a catch handler via case/`~`."
    .test:
    catchByType -> {
        var classify = { |block|
            block.catch:{ |e|
                e.case:{
                    .when:TypeError do:'type';
                    .when:ArgumentError do:'arg';
                    .default:'other';
                }
            }
        };
        .is:{ classify.value:{ TypeError.throw:'x' } } equalTo:'type';
        .is:{ classify.value:{ ArgumentError.throw:'x' } } equalTo:'arg';
        .is:{ classify.value:{ IndexError.throw:'x' } } equalTo:'other';
    };

    "* Default display is `ClassName: message`."
    .test:
    errorDisplay -> {
        .is:{ (TypeError.new:{ var message = 'boom' }).s } equalTo:'TypeError: boom';
    };

    "* User-defined errors just subclass Error."
    .test:
    userDefinedError -> {
        Error <- WidgetError <- {};
        .does:{ WidgetError.throw:'broke' } throw:WidgetError;
        .does:{ WidgetError.throw:'broke' } throw:Error;
    };

    "* Internal runtime errors now surface as structured Error objects you can
    "* dispatch on - and they're still matchable by message via does:throw:."
    .test:
    runtimeTypeErrorIsStructured -> {
        var caught = nil;
        { 'abc'.contains?:5 }.catch:{ |e| caught = e };
        .isTrue:{ caught.class == TypeError };
        .isTrue:{ TypeError ~ caught };
        .does:{ 'abc'.contains?:5 } throw:TypeError;
        .does:{ 'abc'.contains?:5 } throw:#/String/;
    };

    "* An out-of-bounds index surfaces a structured IndexError carrying the offending
    "* index and the collection length (both populated by the VM).
    .test:
    indexErrorIsStructured -> {
        var caught = nil;
        { (Bytes.of:#(10 20 30)).at:10 }.catch:{ |e| caught = e };
        .isTrue:{ IndexError ~ caught };
        .is:{ caught.index } equalTo:10;
        .is:{ caught.length } equalTo:3;

        "* List.at:put: with a bad index throws the same typed error.
        .does:{ var l = #(1 2 3); l.at:10 put:99 } throw:IndexError;
        "* is-an Error, and still matchable by message.
        .does:{ (Bytes.of:#(1 2)).at:5 } throw:Error;
        .does:{ (Bytes.of:#(1 2)).at:5 } throw:#/out of range/;
    };

    "* A value of the right type but invalid content raises a typed ValueError.
    .test:
    valueErrorOnBadContent -> {
        .does:{ Integer.fromHex:'xyz' } throw:ValueError;
        .does:{ Integer.fromHex:'xyz' } throw:Error;
        .does:{ Bytes.of:#(1 2 999) } throw:ValueError;
        "* a malformed host:port is rejected before any connection is attempted.
        .does:{ TcpSocket.connect:'nocolon' } throw:ValueError;
        .does:{ TcpSocket.connect:'host:notaport' } throw:ValueError;
    };

    "* A parse/decode failure of input data raises a typed ParseError (here, bytes that
    "* are not valid UTF-8).
    .test:
    parseErrorOnBadInput -> {
        .does:{ (Bytes.of:#(255 254)).asString } throw:ParseError;
        .does:{ (Bytes.of:#(255 254)).asString } throw:Error;
    };

    "* A syntax error in `Runtime.eval:` / `eval:self:` surfaces a catchable ParseError
    "* instead of panicking the VM (the eval path uses the fallible parser).
    .test:
    evalSyntaxErrorIsCatchable -> {
        .does:{ Runtime.eval:'1 +' } throw:ParseError;
        .does:{ Runtime.eval:'1 +' } throw:Error;
        .does:{ Runtime.eval:'this is (not valid' self:nil } throw:ParseError;
        "* a well-formed eval still returns its value
        .is:{ Runtime.eval:'40 + 2' } equalTo:42;
    };

    "* Methods that enforce an argument's type through the dispatcher (a typed
    "* variant) raise MessageNotUnderstood for a wrong-typed arg - no variant
    "* matches - rather than a hand-rolled TypeError. Correctly typed args dispatch.
    .test:
    typedArgDispatch -> {
        .is:{ #(10 20 30).at:1 } equalTo:20;
        .is:{ (#(10 20 30).sliceFrom:1).count } equalTo:2;
        .is:{ var l = #(1 2 3); l.at:1 put:9; l.at:1 } equalTo:9;
        .is:{ 'abcd'.insert:'X' at:2 } equalTo:'abXcd';

        "* The bad index is laundered through an untyped local: written literally, the
        "* checker (correctly) flags these at check time, and this test is about the
        "* RUNTIME dispatcher's answer.
        var bad = 'x';
        .does:{ #(1 2).at:bad } throw:MessageNotUnderstood;
        .does:{ #(1 2).at:bad put:9 } throw:MessageNotUnderstood;
        .does:{ #(1 2).sliceFrom:bad } throw:MessageNotUnderstood;
        .does:{ 'abcd'.insert:'e' at:bad } throw:MessageNotUnderstood;
    };

    .test:
    runtimeMessageNotUnderstood -> {
        .does:{ 5.bogusMethodXyz } throw:MessageNotUnderstood;
        .does:{ 5.bogusMethodXyz } throw:#/bogusMethodXyz/;
    };

    .test:
    ioErrorCarriesKind -> {
        "* IoError.throw:kind: sets the kind symbol, readable via .kind
        var caught = nil;
        { IoError.throw:'boom' kind:#custom }.catch:{ |e| caught = e };
        .isTrue:{ IoError ~ caught };
        .is:{ caught.kind } equalTo:#custom;
    };

    .test:
    indexErrorCarriesLength -> {
        "* an out-of-bounds at:put: throws IndexError exposing .index and .length
        var caught = nil;
        { #(1 2 3).at:9 put:0 }.catch:{ |e| caught = e };
        .isTrue:{ IndexError ~ caught };
        .is:{ caught.index } equalTo:9;
        .is:{ caught.length } equalTo:3;
    };

    "* Typed `catch:` only catches when the thrown value's type matches the handler's declared
    "* exception param; a non-match re-raises (to an enclosing catch, or out). An untyped `|e|`
    "* handler is a catch-all, and a subtype matches a base-typed handler.
    .test:
    typedCatchMatchesByType -> {
        .is:{ { TypeError.throw:'x' }.catch:{ |e:TypeError| 'caught' } } equalTo:'caught';
        .is:{ { TypeError.throw:'x' }.catch:{ |e:Error| 'base' } } equalTo:'base';
        .is:{ { TypeError.throw:'x' }.catch:{ |e| 'all' } } equalTo:'all';
        "* a non-matching typed catch re-raises rather than swallowing
        .does:{ { TypeError.throw:'x' }.catch:{ |e:ValueError| 'no' } } throw:TypeError;
        "* ...which an enclosing catch can take
        .is:{ { { TypeError.throw:'x' }.catch:{ |e:ValueError| 'in' } }.catch:{ |e:Error| 'out' } }
            equalTo:'out';
    };

    "* `catch:{...} catch:{...} …` (the variadic fold) tries handlers in source order; the first
    "* type match wins, an untyped catch-all goes last, and no match re-raises past the chain.
    .test:
    multiCatchFirstMatchWins -> {
        .is:{
            { TypeError.throw:'x' }
                .catch:{ |e:ValueError| 'v' }
                catch:{ |e:TypeError| 't' }
                catch:{ |e:Error|     'all' }
        } equalTo:'t';
        .is:{
            { TypeError.throw:'x' }.catch:{ |e:ValueError| 'v' } catch:{ |e| 'all' }
        } equalTo:'all';
        .does:{
            { TypeError.throw:'x' }.catch:{ |e:ValueError| 'v' } catch:{ |e:ArgumentError| 'a' }
        } throw:TypeError;
    };

    "* `finally` always runs: after a matched handler, and even when no handler matched and the
    "* error re-raises.
    .test:
    typedCatchFinallyAlwaysRuns -> {
        var log = '';
        .is:{ { TypeError.throw:'x' }.catch:{ |e:TypeError| 'c' } finally:{ log = 'F' } }
            equalTo:'c';
        .is:{ log } equalTo:'F';
        var ran = nil;
        .does:{ { TypeError.throw:'x' }.catch:{ |e:ValueError| 'no' } finally:{ ran = true } }
            throw:TypeError;
        .isTrue:{ ran };
    };

    "* A thrown primitive types by its class (`42` is an Integer); a class handler that doesn't
    "* match falls through to the catch-all.
    .test:
    primitiveThrowTypesByClass -> {
        .is:{ { 42.throw }.catch:{ |e:Integer| 'int' } catch:{ |e| 'other' } } equalTo:'int';
        .is:{ { 42.throw }.catch:{ |e:TypeError| 'te' } catch:{ |e| 'fell' } } equalTo:'fell';
    };
}
