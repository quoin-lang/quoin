"* Interpolation fixtures: a `%'…'` literal lowers to a `+` chain at compile
"* time, so `%{…}` sees the enclosing scope — locals AND instance variables
"* (the runtime reflective path, kept for computed strings, sees locals only).
InterpNamed <- { |@name|
    init: -> { |name| @name = name }
    greet -> { %'Hello, %{@name}!' }
}

InterpCustomS <- {
    s -> { 'CUSTOM' }
}

(TestSuite.new:{ var name = 'Strings' }).add:{
    .test:
    equality -> {
        .is:{ 'abc'.s } equalTo:'abc';
        .is:{ 'abc' + 'def' } equalTo:'abcdef';
        .is:{ 'abcdef' } notEqualTo:'abc';
    };

    .test:
    comparisons -> {
        .is:{ 'aa' } lessThan:'ab';
        .is:{ 'ab' } greaterThan:'aa';
        .is:{ 'aa' } lessThanOrEqualTo:'aa';
        .is:{ 'ab' } greaterThanOrEqualTo:'ab';
        .is:{ 'aa' } lessThanOrEqualTo:'ab';
        .is:{ 'ab' } greaterThanOrEqualTo:'aa';
    };

    .test:
    formatting -> {
        .is:{ '%1-%2-%3' % #(42 43 44) } equalTo:'42-43-44';
        .is:{ '%c-%b-%a' % #{ 'a':42 'b':43 'c':44 } } equalTo:'44-43-42';
        .is:{ %'1%{2}3' } equalTo:'123';
        .is:{ %'1%{1+1}3' } equalTo:'123';
    };

    .test:
    interpolation -> {
        "* Locals resolve lexically; adjacent fragments; a template that
        "* starts with a fragment still concatenates as a String.
        var x = 6;
        .is:{ %'x is %{x}' } equalTo:'x is 6';
        .is:{ %'%{x}%{x + 1}' } equalTo:'67';
        .is:{ %'%{x}' } equalTo:'6';

        "* Instance variables — the compile-time lowering sees them (the old
        "* runtime recompilation silently read them as nil).
        .is:{ (InterpNamed.new:{ var name = 'Ada' }).greet } equalTo:'Hello, Ada!';

        "* Values splice via the same `.s` coercion String#+ applies.
        .is:{ %'v=%{InterpCustomS.new}' } equalTo:'v=CUSTOM';

        "* Braces nest by depth, so block literals work inside a fragment.
        .is:{ %'%{ #(1 2 3).collect:{ |i| i * 2 } }' } equalTo:'#(2 4 6)';

        "* An unterminated `%{` is literal text, not an error.
        .is:{ %'a%{ never closed' } equalTo:'a%{ never closed';

        "* A multi-statement fragment evaluates as a block: its value is the
        "* last statement's, its `var`s stay fragment-local, and an
        "* assignment to an enclosing local writes through.
        .is:{ %'%{var q = 3; q + 1}' } equalTo:'4';
        var q = 'outer';
        .is:{ q } equalTo:'outer';
        .is:{ %'%{x = 60}' } equalTo:'60';
        .is:{ x } equalTo:60;
    };

    .test:
    dynamicInterpolation -> {
        "* Sending `%` to a COMPUTED string takes the runtime reflective
        "* path: `%{…}` re-parses at call time against the caller's locals.
        var x = 6;
        var t = 'x is %{x}';
        .is:{ %t } equalTo:'x is 6';
        "* A malformed fragment there is a catchable ParseError (a malformed
        "* `%'…'` literal is a compile error instead).
        var bad = 'oops %{)}';
        .does:{ %bad } throw:ParseError;
    };

    .test:
    misc -> {
        .is:{ 'abcdefg'.length } equalTo:7;

        .isTrue:{ 'abcd'.contains?:'c' };
        .isTrue:{ 'abcd'.ends?:'d' };
        .isTrue:{ 'abcd'.starts?:'a' };
        .is:{ 'abcd'.index:'c' } equalTo:2;
        .is:{ 'abcd'.insert:'e' at:4 } equalTo:'abcde';

        .is:{ 'AbCdE'.lower } equalTo:'abcde';
        .is:{ 'AbCdE'.upper } equalTo:'ABCDE';

        .is:{ 'foo bar baz'.split:' ' } equalTo:#( 'foo' 'bar' 'baz' );
        .is:{ 'foo   bar  baz '.split:#/\s+/ } equalTo:#( 'foo' 'bar' 'baz' '' );
        .is:{ 'foo   bar  baz '.split } equalTo:#( 'foo' 'bar' 'baz' '' );
    };

    .test:
    multibyteLiterals -> {
        "* String literals measure char length and stop at the closing quote even with
        "* multibyte content. A byte-vs-char slicing bug in the lexer once leaked the
        "* delimiter (so 'µ'.length was 2) — applied to plain and #ANSI'…' strings alike."
        .is:{ 'µ'.length } equalTo:1;
        .is:{ 'abµde'.length } equalTo:5;
        .is:{ 'aµbµc'.length } equalTo:5;
        .is:{ 'café' } equalTo:'café';
        .is:{ 'x' + #ANSI'µs'.string } equalTo:'xµs';
    };

    .test:
    padRight -> {
        "* Pads with trailing spaces to the requested width; a no-op once already wide enough."
        .is:{ 'ab'.padRight:5 } equalTo:'ab   ';
        .is:{ 'ab'.padRight:2 } equalTo:'ab';
        .is:{ 'abcde'.padRight:3 } equalTo:'abcde';
        .is:{ ''.padRight:3 } equalTo:'   ';
        .is:{ ('ab'.padRight:5).length } equalTo:5;
    };

    .test:
    replaceWith -> {
        "* `replace:with:` dispatches on the pattern argument's type: a String
        "* pattern is a literal replace-all, a Regex pattern a regex replace-all.
        .is:{ 'a-b-c'.replace:'-' with:'_' } equalTo:'a_b_c';
        .is:{ 'hello'.replace:'l' with:'L' } equalTo:'heLLo';
        .is:{ 'a1b2c3'.replace:#/[0-9]/ with:'#' } equalTo:'a#b#c#';
        .is:{ 'x   y'.replace:#/\s+/ with:' ' } equalTo:'x y';
        "* A pattern that is neither String nor Regex matches no variant -> MNU.
        .does:{ 'x'.replace:5 with:'y' } throw:MessageNotUnderstood;
    };

    .test:
    joinSemantics -> {
        "* join: is a linear native on List; it must keep the mixin's exact
        "* quirks: the separator appends only while the ACCUMULATED result is
        "* non-empty (an empty first piece suppresses it), elements convert
        "* via `.s`, and non-List receivers still use the Iterate version.
        .is:{ #( 'a' 'b' 'c' ).join:'-' } equalTo:'a-b-c';
        .is:{ #( '' 'a' 'b' ).join:'-' } equalTo:'a-b';
        .is:{ #( 1 2 3 ).join:', ' } equalTo:'1, 2, 3';
        .is:{ #().join:'-' } equalTo:'';
        .is:{ #( 'only' ).join:'-' } equalTo:'only';
        .is:{ (1..4).join:'+' } equalTo:'1+2+3';
    };

    .test:
    literalsShareBuffersNotIdentity -> {
        "* String literals share their immutable inner buffer (one GC alloc
        "* per push instead of two) but every push mints a FRESH value:
        "* eigenclassing one literal's value must not leak into the next
        "* occurrence of the same literal.
        var a = 'eigen-probe';
        a <-- { probeTag -> { ^42 } };
        .is:{ a.probeTag } equalTo:42;
        .does:{ 'eigen-probe'.probeTag } throw:MessageNotUnderstood;
        .is:{ a == 'eigen-probe' } equalTo:true;
    };
}
