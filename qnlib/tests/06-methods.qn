(TestSuite.new:{ var name = 'Methods' }).add:{
    .test:
    operatorReturnsMethod -> {
        .is:{ var method = z -> {}; #( method.selector method.extension? ) } equalTo:#( #z false );
    };

    .test:
    canEndInBang -> {
        .is:{
            TSMTC1 <- { blam! -> { 'Blam!' } };
            TSMTC1.new.blam!
        } equalTo:'Blam!';
    };

    .test:
    dispatchTypePriority -> {
        .is:{
            TSMTC2 <- {
                x: -> { |x:Integer| 'Integer: %' % (x) }
                x: --> { |x:String| 'String: %' % x }
                x: --> { |x:Object| 'Other: %' % x }
            };
            #( TSMTC2.new.x:55 TSMTC2.new.x:'str' TSMTC2.new.x:true )
        } equalTo:#( 'Integer: 55' 'String: str' 'Other: true' );
    };

    .test:
    dispatchByBlock -> {
        "* A guard refines specificity within a type level, so the catch-all is a
        "* plain unguarded |x| (it loses to any guarded variant at the same type
        "* distance) rather than a {.class==Object} guard. No reliance on definition
        "* order — dispatch is purely by (type distance, then guarded-beats-unguarded).
        .is:{
            TSMTC3 <- {
                x: -> { |x { x.class==Integer }| 'Integer: %' % (x) }
                x: --> { |x { x.class==String }| 'String: %' % x }
                x: --> { |x| 'Other: %' % x }
                x: --> { |x:Integer { x > 100 }| 'Big Integer: %' % x }
                x: --> { |x:Integer { x < 0 }| 'Negative Integer: %' % x }
            };
            #( TSMTC3.new.x:55 TSMTC3.new.x:'str' TSMTC3.new.x:true TSMTC3.new.x:150 TSMTC3.new.x:-10 )
        } equalTo:#( 'Integer: 55' 'String: str' 'Other: true' 'Big Integer: 150' 'Negative Integer: -10' );
    };

    "* A guard's `self` is the method's receiver (the subject of the call), so a guard
    "* can use the rest of the class — instance variables and other methods — not just
    "* the arguments (which are bound by name).
    .test:
    dispatchGuardUsesSelf -> {
        Bound <- { |@min|
            .meta <-- { min: -> { |m| ^.new:{ var min = m } } }
            within?: -> { |n:Integer| n >= @min }
            ok?: -> { |n:Integer { .within?:n }| 'yes' }   "* guard calls a method (which reads @min) via self
            ok?: --> { |n:Integer| 'no' }
        };
        .is:{ (Bound.min:10).ok?:15 } equalTo:'yes';
        .is:{ (Bound.min:10).ok?:5 } equalTo:'no';
    };

    "* Two equally-specific UNGUARDED variants (a value that is-a both mixins at the
    "* same hierarchy distance) have no tiebreaker -> AmbiguousMethodError.
    .test:
    dispatchAmbiguityType -> {
        Mixin <- TSMA <- {};
        Mixin <- TSMB <- {};
        TSThing <- { .mix:TSMA; .mix:TSMB; };
        TSPick <- {
            pick: -> { |x:TSMA| 'A' }
            pick: --> { |x:TSMB| 'B' }
        };
        .does:{ TSPick.new.pick:TSThing.new } throw:AmbiguousMethodError;
        "* A non-ambiguous arg (is-a only one mixin) still dispatches cleanly.
        TSThingA <- { .mix:TSMA; };
        .is:{ TSPick.new.pick:TSThingA.new } equalTo:'A';
    };

    "* Two GUARDED variants at the same type level that both pass also tie -> throw.
    "* (A guarded variant beating an unguarded catch-all is fine; two passing guards
    "* with no specificity difference is the ambiguous case.)
    .test:
    dispatchAmbiguityGuard -> {
        TSGuard <- {
            g: -> { |x:Integer {x > 0}| 'pos' }
            g: --> { |x:Integer {x > 5}| 'big' }
        };
        .does:{ TSGuard.new.g:10 } throw:AmbiguousMethodError;   "* 10 passes both
        .is:{ TSGuard.new.g:3 } equalTo:'pos';                   "* only x>0 passes
    };

    .test:
    overridesSameSignature -> {
        "* A later same-signature (unguarded) definition replaces the earlier one,
        "* whether via --> or a repeated ->. Type- and guard-differentiated variants
        "* are unaffected (see dispatchTypePriority / dispatchByBlock).
        .is:{
            TSMTC4 <- { bar -> { 1 } };
            TSMTC4 <-- { bar --> { 2 } };
            TSMTC4.new.bar
        } equalTo:2;
        .is:{
            TSMTC5 <- { bar -> { 'a' } };
            TSMTC5 <-- { bar -> { 'b' } };
            TSMTC5.new.bar
        } equalTo:'b';
    };

    .test:
    dispatchOnClassArg -> {
        "* A `:Class`-typed parameter must match a Class *value* (e.g. `Integer`),
        "* not just instances. Regression: scored dispatch's hierarchy-distance must
        "* treat a Class value as being of type Class rather than walking that
        "* class's own ancestry looking for a class named "Class".
        TSMTC_DC <- {
            kindOf: -> { |x:Class| 'a class' }
            kindOf: --> { |x:Object| 'an object' }
        };
        .is:{ TSMTC_DC.new.kindOf:Integer } equalTo:'a class';   "* a Class -> :Class (distance 0) beats :Object (distance 1)
        .is:{ TSMTC_DC.new.kindOf:5 } equalTo:'an object';        "* an instance -> only :Object matches
    };

    "* A selector that exists but whose variants don't match the argument types
    "* raises MessageNotUnderstood (not a silent mis-dispatch). The displayed error
    "* additionally lists the filtered-out candidate signatures as a hint.
    .test:
    dispatchNoMatchRaisesMNU -> {
        TSMTC_NM <- {
            z: -> { |x:Integer| 'int' }
            z: --> { |x:String {x.length > 3}| 'str' }
        };
        .does:{ TSMTC_NM.new.z:true } throw:MessageNotUnderstood;
        "* a matching arg still dispatches
        .is:{ TSMTC_NM.new.z:5 } equalTo:'int';
    };

    "* Resolving a send memoizes the result in the dispatch cache — including a
    "* *miss* (selector not found). Defining that method afterwards must invalidate
    "* the cache so the new definition is seen, rather than the stale cached miss
    "* keeping the selector 'not understood'. (A same-signature `-->` override is a
    "* weaker test: it mutates the method object in place, so the cached pointer sees
    "* the new body even without invalidation — a fresh definition does not.)
    .test:
    dispatchCacheInvalidatesOnNewMethod -> {
        TSMTC_CN <- { existing -> { 1 } };
        "* `late` is undefined -> resolves to a miss, which gets cached
        .does:{ TSMTC_CN.new.late } throw:MessageNotUnderstood;
        "* now define it; the cached miss must be invalidated
        TSMTC_CN <-- { late -> { 9 } };
        .is:{ TSMTC_CN.new.late } equalTo:9;
    };

    "* A variadic keyword component (declared `name+:`) folds a run of that keyword at
    "* the call site into a single List argument. `gather: 1 gather: 2 gather: 3` is one
    "* send to `gather+:` with `items == #(1 2 3)`.
    .test:
    variadicSelectorFoldsRunIntoList -> {
        TSMTC_V1 <- { gather+: -> { |items| items } };
        .is:{ TSMTC_V1.new.gather: 1 gather: 2 gather: 3 } equalTo:#( 1 2 3 );
    };

    "* The variadic run folds; a following distinct keyword stays its own argument.
    .test:
    variadicSelectorWithTrailingKeyword -> {
        TSMTC_V2 <- { gather+:into: -> { |items target| #( items target ) } };
        .is:{ TSMTC_V2.new.gather: 1 gather: 2 into: 'x' } equalTo:#( #( 1 2 ) 'x' );
    };

    "* A single keyword has nothing to fold, so it routes to the non-variadic `gather:`,
    "* not `gather+:` — the two are distinct selectors.
    .test:
    singleKeywordDoesNotFoldToVariadic -> {
        TSMTC_V3 <- { gather: -> { |x| 'single' } gather+: -> { |items| 'variadic' } };
        .is:{ TSMTC_V3.new.gather: 99 } equalTo:'single';
        .is:{ TSMTC_V3.new.gather: 1 gather: 2 } equalTo:'variadic';
    };

    "* A definition may not repeat a keyword literally — `+` is the only way to declare a
    "* variadic component, so `dup:dup:` is a compile error (surfaced as a ParseError by eval).
    "* A `T?` parameter dispatches as base-type-or-nil (it used to match NOTHING —
    "* the variant was unreachable; RELEASE_PREP Tier 4b). nil matches exactly, a
    "* base-type argument matches at the base's specificity, and typed siblings
    "* still win their own types.
    .test:
    nullableParamsDispatch -> {
        TMNullW <- {
            width: -> { |name: String?| name.defined?.if:{ 'str' } else:{ 'none' } };
            width: --> { |n: Integer| 'int' }
        };
        var w = TMNullW.new;
        .is:{ w.width:'x' } equalTo:'str';
        .is:{ w.width:nil } equalTo:'none';
        .is:{ w.width:7 } equalTo:'int';
        "* A wrong type still refuses (Double matches neither String? nor Integer).
        .does:{ w.width:1.5 } throw:MessageNotUnderstood;
    };

    .test:
    repeatedKeywordSelectorIsACompileError -> {
        .does:{ Runtime.eval:'Bad <- { dup:dup: -> { |a b| a } }' } throw:ParseError;
    };
}
