(TestSuite.new:{ name = 'Async' }).add:{
    "* Stage 1 async I/O: `Runtime.sleep:` parks the running fiber via an AwaitIo
    "* suspension and resumes with a value, all driven by the async IoBackend.

    "* The call round-trips out to the backend and back, returning nil.
    .test:
    sleepReturnsNil -> {
        .is:{ Runtime.sleep: 1 } equalTo:nil;
    };

    "* Lower-bound timing only (non-flaky): a 30ms sleep really parked, proving a
    "* genuine reactor round-trip rather than a no-op.
    .test:
    sleepParksForRequestedTime -> {
        .is:{ Timer.time:{ Runtime.sleep: 30 } } greaterThanOrEqualTo:20;
    };

    "* Stage 2a: `Async.gather:` runs each block as a concurrent task whose I/O
    "* overlaps. Eight 30ms sleeps run together finish in well under the 240ms a
    "* serial run would take — proof the scheduler overlaps parked tasks.
    .test:
    gatherRunsTasksConcurrently -> {
        .is:{ Timer.time:{ Async.gather:#(
            { Runtime.sleep: 30 } { Runtime.sleep: 30 }
            { Runtime.sleep: 30 } { Runtime.sleep: 30 }
            { Runtime.sleep: 30 } { Runtime.sleep: 30 }
            { Runtime.sleep: 30 } { Runtime.sleep: 30 }
        ) } } lessThan:150;
    };

    "* Results come back in spawn order, not completion order: the block that
    "* sleeps longest is first in the list, so its result must still lead.
    .test:
    gatherReturnsResultsInSpawnOrder -> {
        .is:{ Async.gather:#(
            { Runtime.sleep: 30; 1 }
            { Runtime.sleep: 10; 2 }
            { 3 }
        ) } equalTo:#(1 2 3);
    };
}
