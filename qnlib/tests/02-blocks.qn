(TestSuite.new:{ var name = 'Blocks' }).add:{
    .test:
    arity -> {
        .is:{ {}.arity } equalTo:0;
        .is:{ {|x|}.arity } equalTo:1;
        .is:{ {|x y|}.arity } equalTo:2;
        .is:{ {|_ y|}.arity } equalTo:2;
    };

    .test:
    args -> {
        .is:{ {}.args } equalTo:#();
        .is:{ {|x|}.args } equalTo:#( 'x' );
        .is:{ {|x y|}.args } equalTo:#( 'x' 'y' );
        .is:{ {|_ y|}.args } equalTo:#( '_' 'y' );
    };

    .test:
    blockName -> {
        .is:{ {}.name } equalTo:nil;
        .is:{ {#x |-|}.name } equalTo:#x;       "* Block#name returns a symbol
        .is:{ {#x |x|}.name } equalTo:#x;
    };

    .test:
    code -> {
        .is:{ {|a b| a+b }.code } equalTo:'{|a b| a+b }';
    };

    .test:
    captures -> {
        var n = 3;
        var list = #( 1 2 );
        .is:{ { |x| x + n }.captures } equalTo:#{ 'n': 3 };
        .is:{ { |x| (x + n) * list.count }.captures } equalTo:#{ 'n': 3 'list': #( 1 2 ) };
        "* params and locals the block binds itself are not captures
        .is:{ { |x| var y = x; y * 2 }.captures } equalTo:#{};
        "* a write-captured binding is still a free variable with a value
        var m = 1;
        .is:{ { m = m + 1 }.captures } equalTo:#{ 'm': 1 };
        "* nested literals: inner frees resolve, outer params shadow
        var a = 1;
        .is:{ { |x| { |y| x + y + a }.value:2 }.captures } equalTo:#{ 'a': 1 };
        "* the live binding, not a copy: mutation is visible
        var box = #( 0 );
        var watcher = { box.first };
        box.at:0 put:9;
        .is:{ (watcher.captures.at:'box').first } equalTo:9;
    };

    .test:
    value -> {
        .is:{ {1; 2; 3}.value } equalTo:3;
    };

    .test:
    shadowingCapturesAreFreshPerCall -> {
        "* `var x = x` reads the capture BEFORE defining the shadow — a free
        "* read, so this literal must never be judged closed and cached: each
        "* call materializes a fresh closure over the CURRENT frame.
        "* (Regression: with another var in the block, the constant-closure
        "* promotion pinned the first call's environment into every later one.)
        var mk = { |x|
            {
                var x = x
                var y = 0
                x + y
            }
        };
        .is:{ (mk.value:1).value } equalTo:1;
        .is:{ (mk.value:2).value } equalTo:2;
    };

    .test:
    valueArgs -> {
        .is:{ {|n| n*n}.value:3 } equalTo:9;
        .is:{ {|l| (l.at:0) + (l.at:1)}.value:#(10 5) } equalTo:15;
        .is:{ {|x y| x+y}.valueWithArgs:#(10 5) } equalTo:15;
    };

    .test:
    valueSelf -> {
        .is:{ {.s}.valueWithSelf:42 } equalTo:'42';
    };

    .test:
    valueSelfArgs -> {
        .is:{ {|x| .s + x}.value:'bar' withSelf:'foo' } equalTo:'foobar';
        .is:{ {|x y| .s + x + y}.value:#('bar' 'baz') withSelf:'foo' } equalTo:'foobarbaz';
    };

    .test:
    catch -> {
        .is:{ { 42.throw }.catch:{|ex| ex} } equalTo:42;
    };

    .test:
    catchFinally -> {
        var finally = nil;
        .does:{
            { 42.throw }.catch:{|ex| finally = ex } finally:{ finally = 'Finally' }
        }
        resultIn:{
            finally == 'Finally'
        };
    };

    "* Bare `finally:` — cleanup on every path, nothing absorbed (RELEASE_PREP
    "* Tier 4b; replaces the `catch:{|e| e.throw} finally:` idiom).
    .test:
    bareFinally -> {
        "* Success: cleanup runs, the value propagates.
        var log = #();
        .is:{ { 41 + 1 }.finally:{ log.add:'ran' } } equalTo:42;
        .is:{ log } equalTo:#('ran');

        "* Throw: cleanup runs FIRST, then the error re-raises unchanged.
        var order = #();
        { { 'boom'.throw }.finally:{ order.add:'cleaned' } }.catch:{ |e| order.add:e };
        .is:{ order } equalTo:#('cleaned' 'boom');

        "* A typed handler outside still sees the original error type.
        var seen = nil;
        { { ValueError.throw:'v' }.finally:{ nil } }.catch:{ |e: ValueError| seen = e.class.name };
        .is:{ seen } equalTo:'ValueError';

        "* An error thrown by the cleanup overrides a normal result.
        .does:{ { 1 }.finally:{ 'late'.throw } } throw:#/late/;
    };

    "* `^^` unwinding through `.finally:` runs the cleanup and still wins.
    .test:
    finallyRunsOnNonLocalReturn -> {
        var cleaned = false;
        var m = homeFor -> { { ^^7 }.finally:{ cleaned = true }; 99 };
        .is:{ .homeFor } equalTo:7;
        .isTrue:{ cleaned };
    };

    .test:
    match -> {
        .does:{ { .length == 3 } } match:'abc';
        .does:{ { |s| s.length == 3 } } match:'abc';
    };
}
