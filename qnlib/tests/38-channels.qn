"* Channel (src/runtime/channel.rs) — CSP-style async message passing between tasks.
"* `Channel.new` is an unbuffered rendezvous; `Channel.buffered: n` queues up to n values.
"* send:/receive park on the scheduler (like gather/join) when no counterpart is ready;
"* close wakes everyone (receivers see nil / end each:, pending sends fail). Tests that
"* need a task to be parked first synchronize on a marker via `whileDo:` (not a fixed
"* sleep) so they are deterministic under the scheduler-stress shuffle.

(TestSuite.new:{ var name = 'Channels' }).add:{
    .test:
    bufferedSendReceive -> {
        "* within capacity, send/receive need no parking; values come out FIFO.
        var c = Channel.buffered: 3;
        c.send: 1; c.send: 2; c.send: 3;
        .is:{ c.count } equalTo:3;
        .is:{ c.receive } equalTo:1;
        .is:{ c.receive } equalTo:2;
        .is:{ c.receive } equalTo:3;
        .is:{ c.count } equalTo:0;
    };

    .test:
    capacities -> {
        .is:{ Channel.new.capacity } equalTo:0;        "* unbuffered rendezvous
        .is:{ (Channel.buffered: 5).capacity } equalTo:5;
        .does:{ Channel.buffered: -1 } throw:ValueError;
    };

    .test:
    rendezvous -> {
        "* unbuffered: the receiver parks until a spawned sender hands off the value.
        var ch = Channel.new;
        Task.spawn: { ch.send: 42 };
        .is:{ ch.receive } equalTo:42;
    };

    .test:
    senderParksUntilReceived -> {
        "* on an unbuffered channel, send blocks until a receiver takes the value: the
        "* sender records `pre` before sending and `post` after; once it has parked in
        "* send, `post` is still empty — it only completes once we receive.
        var ch = Channel.new;
        var pre = #(); var post = #();
        var h = Task.spawn: { pre.add: 1; ch.send: 9; post.add: 1 };
        { pre.count == 0 }.whileDo:{ Async.sleep: 1 };   "* sender has reached (and parked in) send
        .is:{ post.count } equalTo:0;                    "* send has NOT returned yet
        .is:{ ch.receive } equalTo:9;
        h.join;
        .is:{ post.count } equalTo:1;                    "* send completed only after the receive
    };

    .test:
    bufferedFullSenderParks -> {
        "* capacity 1: the first send buffers and returns; the second blocks until a
        "* receive frees the slot.
        var ch = Channel.buffered: 1;
        var prog = #();
        var h = Task.spawn: { ch.send: 1; prog.add: 'a'; ch.send: 2; prog.add: 'b' };
        { prog.count == 0 }.whileDo:{ Async.sleep: 1 };  "* first send done, second parked
        .is:{ prog } equalTo:#('a');
        .is:{ ch.count } equalTo:1;
        .is:{ ch.receive } equalTo:1;                    "* frees a slot; the parked send proceeds
        .is:{ ch.receive } equalTo:2;
        h.join;
        .is:{ prog } equalTo:#('a' 'b');
    };

    .test:
    fanIn -> {
        "* several senders, one receiver; the sum is order-independent (1..5 == 1,2,3,4).
        var ch = Channel.new;
        (1..5).each:{ |k| Task.spawn: { ch.send: k } };
        var sum = 0;
        (1..5).each:{ |_| sum = sum + ch.receive };
        .is:{ sum } equalTo:10;
    };

    .test:
    closeDrainsThenEachStops -> {
        "* each: yields the buffered values then stops once the channel is closed+empty.
        var ch = Channel.buffered: 4;
        ch.send: 10; ch.send: 20; ch.send: 30;
        ch.close;
        .isTrue:{ ch.closed? };
        var total = 0;
        ch.each:{ |v| total = total + v };
        .is:{ total } equalTo:60;
    };

    .test:
    receiveOnClosedEmptyIsNil -> {
        var ch = Channel.buffered: 2;
        ch.send: 1;
        ch.close;
        .is:{ ch.receive } equalTo:1;       "* buffered values remain receivable after close
        .is:{ ch.receive } equalTo:nil;     "* then closed+empty -> nil
        .is:{ ch.receive } equalTo:nil;     "* idempotent
    };

    .test:
    sendOnClosedThrows -> {
        var ch = Channel.new;
        ch.close;
        .does:{ ch.send: 1 } throw:ValueError;
    };

    .test:
    closeWakesParkedReceiver -> {
        "* a receiver parked on an empty channel is released (with nil) by close.
        var ch = Channel.new;
        var pre = #(); var got = #();
        var h = Task.spawn: { pre.add: 1; got.add: ch.receive };
        { pre.count == 0 }.whileDo:{ Async.sleep: 1 };   "* receiver parked
        ch.close;
        h.join;
        .is:{ got } equalTo:#(nil);
    };

    .test:
    cancelParkedReceiver -> {
        "* cancelling a task parked in receive raises its (uncatchable) Cancelled, runs
        "* finally, and is observable as a cancelled status. The stale waiter it leaves
        "* behind is a harmless ghost — exercised by the next test.
        var ch = Channel.new;
        var entered = #(); var trace = #();
        var h = Task.spawn: {
            { entered.add: 1; ch.receive }.catch:{ |_| nil } finally:{ trace.add: 'finally' }
        };
        { entered.count == 0 }.whileDo:{ Async.sleep: 1 };
        h.cancel;
        .is:{ { h.join }.catch:{ |_| 'observed' } } equalTo:'observed';
        .is:{ h.status } equalTo:'cancelled';
        .is:{ trace } equalTo:#('finally');
    };

    .test:
    ghostWaiterIsSkipped -> {
        "* after a cancelled receiver leaves a ghost in the queue, a fresh send/receive
        "* skips it and still delivers correctly.
        var ch = Channel.new;
        var entered = #();
        var h = Task.spawn: { entered.add: 1; ch.receive };
        { entered.count == 0 }.whileDo:{ Async.sleep: 1 };
        h.cancel;
        { h.join }.catch:{ |_| nil };
        Task.spawn: { ch.send: 5 };
        .is:{ ch.receive } equalTo:5;
    };

    .test:
    gatherProducerConsumer -> {
        "* a producer and a consumer run concurrently over one channel under gather; the
        "* producer closes when done and the consumer drains to a deterministic sum.
        var ch = Channel.buffered: 4;
        var result = Async.gather:#(
            { (1..6).each:{ |k| ch.send: k }; ch.close; 'produced' }
            { var sum = 0; ch.each:{ |v| sum = sum + v }; sum }
        );
        .is:{ result.at: 0 } equalTo:'produced';
        .is:{ result.at: 1 } equalTo:15;     "* 1+2+3+4+5
    };

    .test:
    gcSurvivesHeapChurn -> {
        "* buffered values must survive collection while they sit in the channel: fill
        "* the buffer, churn the heap hard, then confirm every value is intact (this is
        "* the Quoin-level companion to the trace_gc unit test).
        var ch = Channel.buffered: 8;
        (0..8).each:{ |k| ch.send: ('v' + k.s) };
        (0..1000).each:{ |i| (0..10).collect:{ |j| j * i } };
        var out = #();
        (0..8).each:{ |_| out.add: ch.receive };
        .is:{ out } equalTo:#('v0' 'v1' 'v2' 'v3' 'v4' 'v5' 'v6' 'v7');
    };
}
