"* [HTTP]Server slice 1: network-free coverage of the response serializer and
"* reason-phrase table, plus live close-mode round trips driven by the [HTTP]Client
"* and a raw socket — client and server on the same scheduler, so the tests are
"* self-contained (ephemeral 127.0.0.1:0 binds; Async.timeout: guards hangs).
use std:net/http
use std:net/http_server

(TestSuite.new:{ var name = 'HTTPServer' }).add:{
    .test:
    reasonPhrases -> {
        .is:{ [HTTP]ServerResponse.reasonFor:200 } equalTo:'OK';
        .is:{ [HTTP]ServerResponse.reasonFor:431 } equalTo:'Request Header Fields Too Large';
        .is:{ [HTTP]ServerResponse.reasonFor:299 } equalTo:'';  "* unregistered
    };

    .test:
    responseSettersThread -> {
        var resp = (([HTTP]ServerResponse.new:{ var status = 201 })
            .contentType:'text/plain')
            .body:'x';
        .is:{ resp.status } equalTo:201;
        .is:{ resp.headers } equalTo:#( #('Content-Type' 'text/plain') );
        .is:{ resp.body.asString } equalTo:'x';  "* String body converts to Bytes
    };

    .test:
    wireBytesFramesByContentLength -> {
        var resp = ([HTTP]ServerResponse.new:{ var status = 200 }).body:'hi';
        var out = ([HTTP]Server.wireBytesFor:resp connection:'close').asStringLossy;
        .isTrue:{ out.starts?:'HTTP/1.1 200 OK\r\n' };
        .isTrue:{ out.contains?:'Content-Length: 2\r\n' };
        .isTrue:{ out.contains?:'Connection: close\r\n' };
        .isTrue:{ out.contains?:'Date: ' };
        .isTrue:{ out.ends?:'\r\n\r\nhi' };
        "* nil body -> Content-Length: 0; unregistered status -> bare status line;
        "* nil connection (the HTTP/1.1 keep-alive default) -> no Connection header.
        var empty = [HTTP]ServerResponse.new:{ var status = 299 };
        var out2 = ([HTTP]Server.wireBytesFor:empty connection:nil).asStringLossy;
        .isTrue:{ out2.starts?:'HTTP/1.1 299\r\n' };
        .isTrue:{ out2.contains?:'Content-Length: 0\r\n' };
        .isFalse:{ out2.contains?:'Connection:' };
    };

    .test:
    httpDateFormatsRfc1123 -> {
        "* The RFC 9110 example date, round-tripped through a parsed DateTime.
        .is:{ [HTTP]Server.httpDateFor:(DateTime.parse:'1994-11-06T08:49:37Z[UTC]') }
            equalTo:'Sun, 06 Nov 1994 08:49:37 GMT';
        "* a caller-set Date wins over ours
        var resp = ([HTTP]ServerResponse.new:{ var status = 200 })
            .header:'Date' value:'Sun, 06 Nov 1994 08:49:37 GMT';
        var out = ([HTTP]Server.wireBytesFor:resp connection:nil).asStringLossy;
        .is:{ (out.splitString:'Date: ').count } equalTo:2;  "* exactly one
    };

    .test:
    wireBytesKeepsCallerHeaders -> {
        "* Caller headers ride through; a caller-set Content-Length suppresses ours.
        var resp = (([HTTP]ServerResponse.new:{ var status = 404 })
            .header:'X-Trace' value:'abc')
            .header:'content-length' value:'0';
        var out = ([HTTP]Server.wireBytesFor:resp connection:'close').asStringLossy;
        .isTrue:{ out.starts?:'HTTP/1.1 404 Not Found\r\n' };
        .isTrue:{ out.contains?:'X-Trace: abc\r\n' };
        .isFalse:{ out.contains?:'Content-Length:' };                "* ours suppressed
        .is:{ (out.splitString:'content-length').count } equalTo:2;  "* theirs, exactly once
    };

    .test:
    roundTripAgainstClient -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                (([HTTP]ServerResponse.new:{ var status = 200 })
                    .contentType:'text/plain')
                    .body:(req.method + ' ' + req.target + ' 1.' + req.version)
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/hello?x=1')
        };
        .is:{ resp.status } equalTo:200;
        .is:{ resp.body.text } equalTo:'GET /hello?x=1 1.1';
        .is:{ resp.header:'content-type' } equalTo:'text/plain';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    requestHeaderLookupIsCaseInsensitive -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:(req.header:'X-PROBE')
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/')
                headers:#( #('x-probe' 'seen') )
        };
        .is:{ resp.body.text } equalTo:'seen';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    malformedRequestGets400 -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| [HTTP]ServerResponse.new:{ var status = 200 } }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:'BOGUS\r\n\r\n'.asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 400 Bad Request\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    chunkFrameAndHex -> {
        .is:{ [HTTP]Server.hexOf:0 } equalTo:'0';
        .is:{ [HTTP]Server.hexOf:255 } equalTo:'ff';
        .is:{ [HTTP]Server.hexOf:4096 } equalTo:'1000';
        .is:{ ([HTTP]Server.chunkFrame:'abc').asStringLossy } equalTo:'3\r\nabc\r\n';
    };

    .test:
    wireHeadStreamingFramesChunked -> {
        var resp = ([HTTP]ServerResponse.new:{ var status = 200 }).contentType:'text/event-stream';
        var out = ([HTTP]Server.wireHeadFor:resp streaming:true connection:nil).asStringLossy;
        .isTrue:{ out.contains?:'Transfer-Encoding: chunked\r\n' };
        .isFalse:{ out.contains?:'Content-Length' };
        .isFalse:{ out.contains?:'Connection:' };
    };

    .test:
    postBodyRoundTrip -> {
        "* A Content-Length request body drains through the shared [HTTP]Body —
        "* and draining must NOT close the connection the response goes out on.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:('got:' + req.body.text)
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.post:('http://127.0.0.1:' + server.port + '/in') body:'hello body'
        };
        .is:{ resp.status } equalTo:200;
        .is:{ resp.body.text } equalTo:'got:hello body';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    jsonBodyCarriesMediaType -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 })
                    .body:(req.body.mediaType + ':' + ((req.body.json.at:'n') + 1))
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.post:('http://127.0.0.1:' + server.port + '/') body:#{ 'n':41 }
        };
        .is:{ resp.body.text } equalTo:'application/json:42';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    bodylessRequestHasEmptyBody -> {
        "* No CL/TE -> an empty bytes-backed body, so handlers never nil-check.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 })
                    .body:(req.body.empty?.if:{ 'empty' } else:{ 'not' })
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/')
        };
        .is:{ resp.body.text } equalTo:'empty';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    chunkedRequestBodyDrains -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:(req.body.text)
            }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:('POST /up HTTP/1.1\r\nTransfer-Encoding: chunked\r\nConnection: close\r\n\r\n'
                + '3\r\nabc\r\n4\r\ndefg\r\n0\r\n\r\n').asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 200 OK\r\n' };
        .isTrue:{ reply.ends?:'\r\n\r\nabcdefg' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    contentLengthOverLimitGets413 -> {
        "* The Content-Length preflight rejects before the handler ever runs.
        var called = false;
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var maxBodyBytes = 4;
            var handler = { |req|
                called = true;
                [HTTP]ServerResponse.new:{ var status = 200 }
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.post:('http://127.0.0.1:' + server.port + '/') body:'way too big'
        };
        .is:{ resp.status } equalTo:413;
        .isFalse:{ called };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    chunkedBodyOverLimitGets413 -> {
        "* No preflight exists for chunked framing — the ceiling trips while the
        "* handler drains, and the server maps [HTTP]BodyTooLarge to 413.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var maxBodyBytes = 4;
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:(req.body.text)
            }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:('POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n' +
                '3\r\nabc\r\n3\r\ndef\r\n0\r\n\r\n').asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 413 Content Too Large\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    expectHeaderGets100Continue -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:('<' + req.body.text + '>')
            }
        };
        server.start;
        var replies = Async.timeout:5000 do:{
            "* over: consumes the socket, so all I/O goes through the stream
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('POST / HTTP/1.1\r\nContent-Length: 2\r\nExpect: 100-continue\r\n'
                + 'Connection: close\r\n\r\n').asBytes;
            var interim = (s.readUntil:'\r\n\r\n').asStringLossy;
            s.writeAll:('hi'.asBytes);
            #( interim (s.readAll.asStringLossy) )
        };
        .is:{ replies.at:0 } equalTo:'HTTP/1.1 100 Continue\r\n\r\n';
        .isTrue:{ (replies.at:1).starts?:'HTTP/1.1 200 OK\r\n' };
        .isTrue:{ (replies.at:1).ends?:'\r\n\r\n<hi>' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    generatorBodyStreamsChunked -> {
        "* A Generator body goes out as chunked transfer-encoding, one frame per
        "* yield — the existing client decodes it from the other side for free.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 })
                    .body:(Generator.from:{ ^>'first '; ^>'second' })
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/stream')
        };
        .is:{ (resp.header:'transfer-encoding') } equalTo:'chunked';
        .is:{ resp.body.text } equalTo:'first second';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    headSuppressesBodyKeepsHeaders -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                (([HTTP]ServerResponse.new:{ var status = 200 })
                    .contentType:'text/plain')
                    .body:'hello'
            }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:('HEAD / HTTP/1.1\r\nConnection: close\r\n\r\n').asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.contains?:'Content-Length: 5\r\n' };
        .isTrue:{ reply.ends?:'\r\n\r\n' };  "* entity headers, no body bytes
        server.stop;
        server.join;
        server.close;
    };

    .test:
    keepAliveServesSequentialRequests -> {
        var served = 0;
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                served = served + 1;
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:('r' + served + '.')
            }
        };
        server.start;
        var replies = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET /a HTTP/1.1\r\n\r\n').asBytes;
            var h1 = (s.readUntil:'\r\n\r\n').asStringLossy;
            var b1 = (s.readExactly:3).asString;
            s.writeAll:('GET /b HTTP/1.1\r\n\r\n').asBytes;
            var h2 = (s.readUntil:'\r\n\r\n').asStringLossy;
            var b2 = (s.readExactly:3).asString;
            s.close;
            #( h1 b1 h2 b2 )
        };
        "* both served on ONE connection; a persistent HTTP/1.1 response carries
        "* no Connection header, but always a Date.
        .is:{ replies.at:1 } equalTo:'r1.';
        .is:{ replies.at:3 } equalTo:'r2.';
        .isFalse:{ (replies.at:0).contains?:'Connection:' };
        .isTrue:{ (replies.at:0).contains?:'Date: ' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    connectionCloseIsHonored -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| ([HTTP]ServerResponse.new:{ var status = 200 }).body:'x' }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET / HTTP/1.1\r\nConnection: close\r\n\r\n').asBytes;
            s.readAll.asStringLossy  "* readAll returning proves the server closed
        };
        .isTrue:{ reply.contains?:'Connection: close\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    http10ClosesByDefaultAndPersistsOnRequest -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| ([HTTP]ServerResponse.new:{ var status = 200 }).body:'ten' }
        };
        server.start;
        var plain = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET / HTTP/1.0\r\n\r\n').asBytes;
            s.readAll.asStringLossy
        };
        .isTrue:{ plain.contains?:'Connection: close\r\n' };
        var kept = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET / HTTP/1.0\r\nConnection: keep-alive\r\n\r\n').asBytes;
            var h1 = (s.readUntil:'\r\n\r\n').asStringLossy;
            s.readExactly:3;
            s.writeAll:('GET / HTTP/1.0\r\nConnection: keep-alive\r\n\r\n').asBytes;
            var h2 = (s.readUntil:'\r\n\r\n').asStringLossy;
            s.close;
            #( h1 h2 )
        };
        .isTrue:{ (kept.at:0).contains?:'Connection: keep-alive\r\n' };
        .isTrue:{ (kept.at:1).starts?:'HTTP/1.1 200 OK\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    oversizedHeadGets431 -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var maxHeadBytes = 256;
            var handler = { |req| [HTTP]ServerResponse.new:{ var status = 200 } }
        };
        server.start;
        "* Oversized but well-formed header lines -> the accumulated-head cap.
        var big = 'aaaaaaaaaaaaaaaa';
        { big.length < 400 }.whileDo:{ big = big + big };
        var lines = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET / HTTP/1.1\r\nX-Big: ' + big + '\r\n\r\n').asBytes;
            s.readAll.asStringLossy
        };
        .isTrue:{ lines.starts?:'HTTP/1.1 431 Request Header Fields Too Large\r\n' };
        "* A delimiter-less flood -> the native readUntil:limit: bound, no timeout
        "* needed. (The flood exceeds the cap, so the server answers mid-write;
        "* catch the possible broken-pipe on our final writes.)
        var flood = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            { s.writeAll:('GET / HTTP/1.1\r\nX-Flood: ' + big + big).asBytes }.catch:{};
            s.readAll.asStringLossy
        };
        .isTrue:{ flood.starts?:'HTTP/1.1 431' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    idleKeepAliveClosesQuietly -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var idleTimeoutMs = 60;
            var handler = { |req| ([HTTP]ServerResponse.new:{ var status = 200 }).body:'x' }
        };
        server.start;
        var tail = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET / HTTP/1.1\r\n\r\n').asBytes;
            s.readUntil:'\r\n\r\n';
            s.readExactly:1;
            "* send nothing more: the idle timeout closes with no response owed
            s.readAll.asStringLossy
        };
        .is:{ tail } equalTo:'';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    stalledHeadGets408 -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var headTimeoutMs = 60;
            var handler = { |req| [HTTP]ServerResponse.new:{ var status = 200 } }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('GET / HT').asBytes;  "* ...and never finish the head
            s.readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 408 Request Timeout\r\n' };
        .isTrue:{ reply.contains?:'Connection: close\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    unreadBodyAutoDrains -> {
        "* The handler ignores the request body; the server must drain it anyway
        "* so the next request on the connection starts at a message boundary.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| ([HTTP]ServerResponse.new:{ var status = 200 }).body:'ok.' }
        };
        server.start;
        var second = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('POST /up HTTP/1.1\r\nContent-Length: 5\r\n\r\nhello').asBytes;
            s.readUntil:'\r\n\r\n';
            s.readExactly:3;
            s.writeAll:('GET /next HTTP/1.1\r\n\r\n').asBytes;
            var h2 = (s.readUntil:'\r\n\r\n').asStringLossy;
            s.close;
            h2
        };
        .isTrue:{ second.starts?:'HTTP/1.1 200 OK\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    overMaxConnectionsGets503 -> {
        "* maxConnections 0 refuses every connection — degenerate, but it pins the
        "* saturation path deterministically.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var maxConnections = 0;
            var handler = { |req| [HTTP]ServerResponse.new:{ var status = 200 } }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 503 Service Unavailable\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    readUntilLimitBoundsDelimiterlessInput -> {
        "* Direct coverage of the ByteStream primitive the head reader leans on: a
        "* delimiter within budget returns normally (even with more bytes buffered
        "* behind it); a delimiter-less run past the limit throws #limitExceeded.
        var listener = TcpListener.listen:'127.0.0.1:0';
        var results = Async.timeout:5000 do:{
            Async.gather:#(
                { listener.acceptOnce:{ |conn|
                    conn.writeAll:('line one\r\nxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx').asBytes }
                }
                {
                    var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + listener.port.s));
                    var first = (s.readUntil:'\r\n' limit:16).asString;
                    var kind = nil;
                    { s.readUntil:'\r\n' limit:16 }.catch:{ |e:IoError| kind = e.kind };
                    s.close;
                    #( first kind )
                }
            )
        };
        listener.close;
        .is:{ (results.at:1).at:0 } equalTo:'line one\r\n';
        .is:{ (results.at:1).at:1 } equalTo:#limitExceeded;
    };

    .test:
    handlerThrowGets500 -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| ValueError.throw:'boom' }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/')
        };
        .is:{ resp.status } equalTo:500;
        .is:{ resp.body.text } equalTo:'';
        server.stop;
        server.join;
        server.close;
    };
}
