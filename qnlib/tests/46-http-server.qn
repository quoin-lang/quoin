"* [HTTP]Server slice 1: network-free coverage of the response serializer and
"* reason-phrase table, plus live close-mode round trips driven by the [HTTP]Client
"* and a raw socket — client and server on the same scheduler, so the tests are
"* self-contained (ephemeral 127.0.0.1:0 binds; Async.timeout: guards hangs).
use std:net/http;
use std:net/http_server;

(TestSuite.new:{ var name = 'HTTPServer' }).add:{
    .test:
    reasonPhrases -> {
        .is:{ [HTTP]ServerResponse.reasonFor:200 } equalTo:'OK';
        .is:{ [HTTP]ServerResponse.reasonFor:431 } equalTo:'Request Header Fields Too Large';
        .is:{ [HTTP]ServerResponse.reasonFor:299 } equalTo:'';  "* unregistered
    };

    .test:
    responseSettersThread -> {
        var resp = (([HTTP]ServerResponse.new:{ var status = 201 })
            .contentType:'text/plain')
            .body:'x';
        .is:{ resp.status } equalTo:201;
        .is:{ resp.headers } equalTo:#( #('Content-Type' 'text/plain') );
        .is:{ resp.body.asString } equalTo:'x';  "* String body converts to Bytes
    };

    .test:
    wireBytesFramesByContentLength -> {
        var resp = ([HTTP]ServerResponse.new:{ var status = 200 }).body:'hi';
        .is:{ ([HTTP]Server.wireBytesFor:resp).asStringLossy }
            equalTo:'HTTP/1.1 200 OK\r\nContent-Length: 2\r\nConnection: close\r\n\r\nhi';
        "* nil body -> Content-Length: 0; unregistered status -> bare status line.
        var empty = [HTTP]ServerResponse.new:{ var status = 299 };
        .is:{ ([HTTP]Server.wireBytesFor:empty).asStringLossy }
            equalTo:'HTTP/1.1 299\r\nContent-Length: 0\r\nConnection: close\r\n\r\n';
    };

    .test:
    wireBytesKeepsCallerHeaders -> {
        "* Caller headers ride through; a caller-set Content-Length suppresses ours.
        var resp = (([HTTP]ServerResponse.new:{ var status = 404 })
            .header:'X-Trace' value:'abc')
            .header:'content-length' value:'0';
        var out = ([HTTP]Server.wireBytesFor:resp).asStringLossy;
        .isTrue:{ out.starts?:'HTTP/1.1 404 Not Found\r\n' };
        .isTrue:{ out.contains?:'X-Trace: abc\r\n' };
        .isFalse:{ out.contains?:'Content-Length:' };                "* ours suppressed
        .is:{ (out.splitString:'content-length').count } equalTo:2;  "* theirs, exactly once
    };

    .test:
    roundTripAgainstClient -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                (([HTTP]ServerResponse.new:{ var status = 200 })
                    .contentType:'text/plain')
                    .body:(req.method + ' ' + req.target + ' 1.' + req.version)
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/hello?x=1')
        };
        .is:{ resp.status } equalTo:200;
        .is:{ resp.body.text } equalTo:'GET /hello?x=1 1.1';
        .is:{ resp.header:'content-type' } equalTo:'text/plain';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    requestHeaderLookupIsCaseInsensitive -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:(req.header:'X-PROBE')
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/')
                headers:#( #('x-probe' 'seen') )
        };
        .is:{ resp.body.text } equalTo:'seen';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    malformedRequestGets400 -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| [HTTP]ServerResponse.new:{ var status = 200 } }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:'BOGUS\r\n\r\n'.asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 400 Bad Request\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    chunkFrameAndHex -> {
        .is:{ [HTTP]Server.hexOf:0 } equalTo:'0';
        .is:{ [HTTP]Server.hexOf:255 } equalTo:'ff';
        .is:{ [HTTP]Server.hexOf:4096 } equalTo:'1000';
        .is:{ ([HTTP]Server.chunkFrame:'abc').asStringLossy } equalTo:'3\r\nabc\r\n';
    };

    .test:
    wireHeadStreamingFramesChunked -> {
        var resp = ([HTTP]ServerResponse.new:{ var status = 200 }).contentType:'text/event-stream';
        var out = ([HTTP]Server.wireHeadFor:resp streaming:true).asStringLossy;
        .isTrue:{ out.contains?:'Transfer-Encoding: chunked\r\n' };
        .isFalse:{ out.contains?:'Content-Length' };
    };

    .test:
    postBodyRoundTrip -> {
        "* A Content-Length request body drains through the shared [HTTP]Body —
        "* and draining must NOT close the connection the response goes out on.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:('got:' + req.body.text)
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.post:('http://127.0.0.1:' + server.port + '/in') body:'hello body'
        };
        .is:{ resp.status } equalTo:200;
        .is:{ resp.body.text } equalTo:'got:hello body';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    jsonBodyCarriesMediaType -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 })
                    .body:(req.body.mediaType + ':' + ((req.body.json.at:'n') + 1))
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.post:('http://127.0.0.1:' + server.port + '/') body:#{ 'n':41 }
        };
        .is:{ resp.body.text } equalTo:'application/json:42';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    bodylessRequestHasEmptyBody -> {
        "* No CL/TE -> an empty bytes-backed body, so handlers never nil-check.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 })
                    .body:(req.body.empty?.if:{ 'empty' } else:{ 'not' })
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/')
        };
        .is:{ resp.body.text } equalTo:'empty';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    chunkedRequestBodyDrains -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:(req.body.text)
            }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:('POST /up HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n' +
                '3\r\nabc\r\n4\r\ndefg\r\n0\r\n\r\n').asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 200 OK\r\n' };
        .isTrue:{ reply.ends?:'\r\n\r\nabcdefg' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    contentLengthOverLimitGets413 -> {
        "* The Content-Length preflight rejects before the handler ever runs.
        var called = false;
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var maxBodyBytes = 4;
            var handler = { |req|
                called = true;
                [HTTP]ServerResponse.new:{ var status = 200 }
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.post:('http://127.0.0.1:' + server.port + '/') body:'way too big'
        };
        .is:{ resp.status } equalTo:413;
        .isFalse:{ called };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    chunkedBodyOverLimitGets413 -> {
        "* No preflight exists for chunked framing — the ceiling trips while the
        "* handler drains, and the server maps [HTTP]BodyTooLarge to 413.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var maxBodyBytes = 4;
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:(req.body.text)
            }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:('POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n' +
                '3\r\nabc\r\n3\r\ndef\r\n0\r\n\r\n').asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.starts?:'HTTP/1.1 413 Content Too Large\r\n' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    expectHeaderGets100Continue -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 }).body:('<' + req.body.text + '>')
            }
        };
        server.start;
        var replies = Async.timeout:5000 do:{
            "* over: consumes the socket, so all I/O goes through the stream
            var s = ByteStream.over:(TcpSocket.connect:('127.0.0.1:' + server.port));
            s.writeAll:('POST / HTTP/1.1\r\nContent-Length: 2\r\nExpect: 100-continue\r\n\r\n').asBytes;
            var interim = (s.readUntil:'\r\n\r\n').asStringLossy;
            s.writeAll:('hi'.asBytes);
            #( interim (s.readAll.asStringLossy) )
        };
        .is:{ replies.at:0 } equalTo:'HTTP/1.1 100 Continue\r\n\r\n';
        .isTrue:{ (replies.at:1).starts?:'HTTP/1.1 200 OK\r\n' };
        .isTrue:{ (replies.at:1).ends?:'\r\n\r\n<hi>' };
        server.stop;
        server.join;
        server.close;
    };

    .test:
    generatorBodyStreamsChunked -> {
        "* A Generator body goes out as chunked transfer-encoding, one frame per
        "* yield — the existing client decodes it from the other side for free.
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                ([HTTP]ServerResponse.new:{ var status = 200 })
                    .body:(Generator.from:{ ^>'first '; ^>'second' })
            }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/stream')
        };
        .is:{ (resp.header:'transfer-encoding') } equalTo:'chunked';
        .is:{ resp.body.text } equalTo:'first second';
        server.stop;
        server.join;
        server.close;
    };

    .test:
    headSuppressesBodyKeepsHeaders -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req|
                (([HTTP]ServerResponse.new:{ var status = 200 })
                    .contentType:'text/plain')
                    .body:'hello'
            }
        };
        server.start;
        var reply = Async.timeout:5000 do:{
            var c = TcpSocket.connect:('127.0.0.1:' + server.port);
            c.writeAll:('HEAD / HTTP/1.1\r\n\r\n').asBytes;
            (ByteStream.over:c).readAll.asStringLossy
        };
        .isTrue:{ reply.contains?:'Content-Length: 5\r\n' };
        .isTrue:{ reply.ends?:'\r\n\r\n' };  "* entity headers, no body bytes
        server.stop;
        server.join;
        server.close;
    };

    .test:
    handlerThrowGets500 -> {
        var server = [HTTP]Server.new:{
            var address = '127.0.0.1:0';
            var handler = { |req| ValueError.throw:'boom' }
        };
        server.start;
        var resp = Async.timeout:5000 do:{
            [HTTP]Client.get:('http://127.0.0.1:' + server.port + '/')
        };
        .is:{ resp.status } equalTo:500;
        .is:{ resp.body.text } equalTo:'';
        server.stop;
        server.join;
        server.close;
    };
}
