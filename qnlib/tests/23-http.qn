"* Network-free coverage of the [HTTP] client's pure logic (URL parsing, request
"* serialization, the Response object). The full round-trip lives in tests/http.rs.
use std:net/http;

(TestSuite.new:{ name = 'HTTP' }).add:{
    .test:
    parsesUrlWithPortAndPath -> {
        .is:{ [HTTP]Request.parseUrl: 'https://example.org:8443/a/b' }
            equalTo:#( 'https' 'example.org' '8443' '/a/b' );
    };

    .test:
    parsesUrlDefaultsPortAndPath -> {
        .is:{ [HTTP]Request.parseUrl: 'http://localhost' } equalTo:#( 'http' 'localhost' '80' '/' );
        .is:{ [HTTP]Request.parseUrl: 'https://localhost' } equalTo:#( 'https' 'localhost' '443' '/' );
    };

    .test:
    buildsRequestBytes -> {
        r = [HTTP]Request.new:{ url = 'http://h/p' };
        r.method:'POST';
        r.body:'hi'.asBytes;
        .is:{ (r.requestBytes:'h' path:'/p').asStringLossy }
            equalTo:'POST /p HTTP/1.1\r\nHost: h\r\nAccept-Encoding: gzip, zstd\r\nContent-Length: 2\r\nConnection: close\r\n\r\nhi';
    };

    .test:
    callerAcceptEncodingSuppressesDefault -> {
        r = [HTTP]Request.new:{ url = 'http://h/p' };
        r.header:'Accept-Encoding' value:'identity';
        out = (r.requestBytes:'h' path:'/p').asStringLossy;
        .isTrue:{ out.contains?:'Accept-Encoding: identity' };
        .isFalse:{ out.contains?:'gzip' };
    };

    .test:
    decodesContentEncoding -> {
        "* decodeBody:encoding: inflates gzip/deflate; identity (or unknown) passes through.
        "* zstd decode is covered by the Rust suite (no pure-Quoin zstd compressor to round-trip).
        .is:{ ([HTTP]Response.decodeBody:('hello'.asBytes.encodeGz) encoding:'gzip').asString }
            equalTo:'hello';
        .is:{ ([HTTP]Response.decodeBody:('world'.asBytes.encodeDeflate) encoding:'deflate').asString }
            equalTo:'world';
        .is:{ ([HTTP]Response.decodeBody:('plain'.asBytes) encoding:'identity').asString }
            equalTo:'plain';
    };

    .test:
    responseHeaderLookupIsCaseInsensitive -> {
        resp = [HTTP]Response.new:{ status = 200; reason = 'OK';
            headers = #( #('Content-Type' 'text/plain') ); body = [HTTP]Body.of:('x'.asBytes) };
        .is:{ resp.header:'CONTENT-TYPE' } equalTo:'text/plain';
        .is:{ (resp.header:'missing').defined? } equalTo:false;
        .is:{ resp.ok? } equalTo:true;
        .is:{ resp.body.text } equalTo:'x';
    };

    .test:
    bodyViews -> {
        "* One [HTTP]Body exposes bytes / text / json views + parsed media type.
        b = [HTTP]Body.of:('{"x": 1}'.asBytes) contentType:'application/json; charset=utf-8' encoding:nil;
        .is:{ b.text } equalTo:'{"x": 1}';
        .is:{ b.mediaType } equalTo:'application/json';
        .isTrue:{ b.json? };
        .is:{ (b.json).at:'x' } equalTo:1;
        .is:{ b.size } equalTo:8;
    };

    .test:
    bytesBodyChunksYieldOnce -> {
        "* The uniform .chunks protocol: a bytes-backed body yields *itself* as one chunk
        "* (an empty body yields none). Each yield is an [HTTP]Body, so .text/.meta apply.
        "* Stream-backed chunking + chunk extensions are covered in tests/http.rs.
        one = ([HTTP]Body.of:('abc'.asBytes)).chunks.list;
        .is:{ one.count } equalTo:1;
        .is:{ (one.at:0).text } equalTo:'abc';
        .is:{ (one.at:0).meta } equalTo:#{};          "* no per-chunk metadata
        .is:{ ([HTTP]Body.of:(Bytes.empty)).chunks.collect:{ |c| c.text } } equalTo:#( );
    };

    .test:
    postMapAutoEncodesJson -> {
        r = [HTTP]Request.new:{ url = 'http://h/p' };
        r.method:'POST';
        r.body:#{ 'name':'qn' 'n':2 };
        .is:{ r.body.mediaType } equalTo:'application/json';
        out = (r.requestBytes:'h' path:'/p').asStringLossy;
        .isTrue:{ out.contains?:'Content-Type: application/json' };
        .isTrue:{ out.contains?:'{"name":"qn","n":2}' };
    };

    .test:
    bodyShortcutTypes -> {
        "* String -> UTF-8 bytes (no media type); a pre-built [HTTP]Body is used directly.
        rs = ([HTTP]Request.new:{ url = 'http://h/p' }).body:'raw';
        .is:{ rs.body.text } equalTo:'raw';
        .is:{ (rs.body.mediaType).defined? } equalTo:false;
        pre = [HTTP]Body.of:('z'.asBytes) contentType:'text/plain' encoding:nil;
        rb = ([HTTP]Request.new:{ url = 'http://h/p' }).body:pre;
        .is:{ rb.body.mediaType } equalTo:'text/plain';
    };
};
