"* Streaming gzip over registry streams (src/io_codecs.rs table + the generic
"* IoRequest::WrapStream): `byteStream.gunzip` / `stringStream.gunzip` wrap the
"* stream IN PLACE, so everything downstream (readAll, readLine, the tar reader)
"* sees decompressed bytes without materializing the whole. The write side
"* (`gzip`) is the encoder twin: `close` FINISHES it (IoRequest::FinishStream
"* drives the poll_close that writes the trailer) — the tests below pin the
"* trailer's presence with a strict decode and the system gzip.
(TestSuite.new:{ var name = 'GzipStream' }).add:{
    .test:
    roundTripAcrossChunkBoundaries -> {
        "* Well past the 16 KiB fill-buffer size, so the decoder spans many chunks.
        var payload = ((1..5000).collect:{ |i| 'line-%1-%2' % #( i (i * 7) ) }).join:'
';
        var p = '/tmp/qn_t_gz_round.gz';
        var w = [IO]File.create:p;
        w.writeAll:(payload.asBytes.encodeGz);
        w.close;
        .is:{ (([IO]File.open:p).byteStream.gunzip.readAll).asString } equalTo:payload;
        [IO]File.delete:p;
    };

    .test:
    multipleMembersDecodeEndToEnd -> {
        "* Concatenated gzip members (how some tools produce .gz) decode as one.
        var p = '/tmp/qn_t_gz_multi.gz';
        var w = [IO]File.create:p;
        w.writeAll:('first '.asBytes.encodeGz);
        w.writeAll:('second'.asBytes.encodeGz);
        w.close;
        .is:{ (([IO]File.open:p).byteStream.gunzip.readAll).asString } equalTo:'first second';
        [IO]File.delete:p;
    };

    .test:
    linesOverGunzip -> {
        "* The point of wrapping in place: the native line machinery just works.
        var p = '/tmp/qn_t_gz_lines.gz';
        var w = [IO]File.create:p;
        w.writeAll:('alpha
beta
gamma'.asBytes.encodeGz);
        w.close;
        var s = ([IO]File.open:p).stringStream.gunzip;
        .is:{ s.readLine } equalTo:'alpha';
        .is:{ s.readLine } equalTo:'beta';
        .is:{ s.readLine } equalTo:'gamma';
        .is:{ s.readLine } equalTo:nil;
        s.close;
        [IO]File.delete:p;
    };

    .test:
    guardsAndErrors -> {
        var p = '/tmp/qn_t_gz_guard.gz';
        var w = [IO]File.create:p;
        w.writeAll:'not gzip at all'.asBytes;
        w.close;
        "* An unknown codec errs and leaves the stream usable.
        var s = ([IO]File.open:p).byteStream;
        { s.codecWrap:'nope'; !!! }
            .catch:{ |e:IoError| .is:{ e.message } equalTo:'unknown stream codec \'nope\'' };
        .is:{ s.readAll.asString } equalTo:'not gzip at all';
        "* Wrapping after a read refuses (buffered raw bytes would be lost).
        var r = ([IO]File.open:p).byteStream;
        r.read:1;
        .does:{ r.gunzip } throw:IoError;
        r.close;
        "* Corrupt input surfaces as a catchable IoError on read.
        .does:{ ([IO]File.open:p).byteStream.gunzip.readAll } throw:IoError;
        "* A write stream has no read side to wrap.
        var ws = [IO]File.create:p;
        .does:{ ws.codecWrap:'gunzip' } throw:IoError;
        ws.close;
        [IO]File.delete:p;
    };

    .test:
    writeRoundTrip -> {
        "* Well past the 16 KiB write buffer, so the encoder spans many drains.
        var p = '/tmp/qn_t_gz_write.gz';
        var payload = ((1..5000).collect:{ |i| 'line-%1-%2' % #( i (i * 3) ) }).join:',';
        var w = ([IO]File.create:p).gzip;
        w.writeAll:payload.asBytes;
        w.close;
        "* decodeGz (the materialized twin) validates the stream strictly — a
        "* missing trailer would throw here...
        .is:{ ([IO]File.open:p).byteStream.readAll.decodeGz.asString } equalTo:payload;
        "* ...and the system gzip agrees the file is whole.
        .is:{ ([OS]Process.run:#( 'gzip' '-t' p )).exitCode } equalTo:0;
        [IO]File.delete:p;
    };

    .test:
    textThroughStringStream -> {
        "* The finish duty transfers through stringStream consumption: a .log.gz
        "* written line by line.
        var p = '/tmp/qn_t_gz_text.gz';
        var s = ([IO]File.create:p).gzip.stringStream;
        s.writeln:'alpha';
        s.writeln:'beta';
        s.close;
        var r = ([IO]File.open:p).stringStream.gunzip;
        .is:{ r.readLine } equalTo:'alpha';
        .is:{ r.readLine } equalTo:'beta';
        .is:{ r.readLine } equalTo:nil;
        r.close;
        [IO]File.delete:p;
    };

    .test:
    writeGuards -> {
        var p = '/tmp/qn_t_gz_wguard.gz';
        "* gzip wraps only a not-yet-written file write stream...
        var w = [IO]File.create:p;
        w.writeAll:'x'.asBytes;
        .does:{ w.gzip } throw:IoError;
        w.close;
        "* ...never a read stream (wrapping the write side would sever reads).
        .does:{ ([IO]File.open:p).byteStream.gzip } throw:IoError;
        "* Double close is a no-op — the finish runs once.
        var w2 = ([IO]File.create:p).gzip;
        w2.writeAll:'ok'.asBytes;
        w2.close;
        w2.close;
        .is:{ ([IO]File.open:p).byteStream.gunzip.readAll.asString } equalTo:'ok';
        [IO]File.delete:p;
    };

    .test:
    scopedThrowStillFinishes -> {
        "* The throw path can't park, so it reaps — and the driver drain FINISHES
        "* a write-codec stream instead of dropping it. Buffered-but-unflushed
        "* text goes down with the error by contract, so the file must come out
        "* VALID and EMPTY, not truncated.
        var p = '/tmp/qn_t_gz_scoped.gz';
        {
            StringStream.over:(([IO]File.create:p).gzip) do:{ |s|
                s.writeln:'goes down with the error'
                ValueError.throw:'boom'
            }
        }.catch:{ |e:ValueError| nil };
        "* Parking here idles the scheduler, which drains the reap first.
        Async.sleep:50;
        .is:{ ([IO]File.open:p).byteStream.gunzip.readAll.count } equalTo:0;
        [IO]File.delete:p;
    };
}
