"* Checked generic collections (docs/GENERICS_ARCH.md): runtime element tags.
"* G1 semantics — insertion enforcement, construction, ensure:, introspection,
"* tag-aware dispatch. Untagged collections are the entire pre-existing world
"* and must behave exactly as before (the corpus is that regression test).

RenderG <- {
    .meta <-- {
        show: -> { |xs: List(Integer)| 'ints' };
        show: -> { |xs: List(String)| 'strings' };
        show: -> { |xs: List| 'plain' }
    }
};

ShapeG <- {
    area -> { 0 }
};
ShapeG <- CircleG <- {
    area -> { 314 }
};

(TestSuite.new:{ var name = 'CheckedGenerics' }).add:{
    .test:
    taggedLiteralConstructsAndEnforces -> {
        var xs: List(Integer) = #(1 2 3);
        .is:{ xs.elementType } equalTo:#Integer;
        xs.add:4;
        .is:{ xs.count } equalTo:4;
        "* the bad value arrives dynamically (an untyped read), as it would in
        "* real code - a statically-visible mismatch would warn at compile time
        var bad = #('nope').at:0;
        .is:{ { xs.add:bad }.catch:{ |e| 'caught' } } equalTo:'caught';
        .is:{ xs.count } equalTo:4;
    };

    .test:
    taggedLiteralChecksItsElements -> {
        "* The bad element is laundered through an untyped local: written literally the
        "* checker (correctly) flags it at check time, and this test is about the
        "* RUNTIME tag enforcement.
        var two = 'two';
        .is:{ { var bad: List(Integer) = #(1 two 3); bad }.catch:{ |e| 'caught' } }
            equalTo:'caught';
    };

    "* The devirtualized at:put: path (statically-typed receiver) enforces too,
    "* and the tag check wins over the bounds check (the VALUE is illegal
    "* regardless of index).
    .test:
    devirtWritePathEnforces -> {
        var xs: List(Integer) = #(1 2 3);
        var bad = #('bad').at:0;
        .is:{ { xs.at:0 put:bad }.catch:{ |e| 'caught' } } equalTo:'caught';
        .is:{ xs.at:0 } equalTo:1;
        .is:{ { xs.at:99 put:bad }.catch:{ |e| 'caught' } } equalTo:'caught';
    };

    .test:
    ofConstructorsAndEnsure -> {
        var dst = List.of:Integer;
        .is:{ dst.elementType } equalTo:#Integer;
        #(7 8 9).each:{ |x| dst.add:(x * 2) };
        .is:{ dst.at:2 } equalTo:18;

        var raw = #(1 2);
        var checked = raw.ensure:Integer;
        .is:{ checked.elementType } equalTo:#Integer;
        "ensure: returns a NEW list; the original stays untagged"
        .is:{ raw.elementType } equalTo:nil;
        raw.add:'still fine';
        .is:{ { #(1 'two').ensure:Integer }.catch:{ |e| 'caught' } } equalTo:'caught';
    };

    .test:
    nilElementsAlwaysAllowed -> {
        var xs = List.of:Integer;
        xs.add:nil;
        xs.add:5;
        .is:{ xs.count } equalTo:2;
    };

    .test:
    sliceCarriesTheTag -> {
        var xs: List(Integer) = #(1 2 3 4);
        .is:{ (xs.sliceFrom:2).elementType } equalTo:#Integer;
    };

    .test:
    mapValuesAndSetElements -> {
        var m = Map.of:Integer;
        m.at:'a' put:1;
        .is:{ m.elementType } equalTo:#Integer;
        var badV = #('x').at:0;
        .is:{ { m.at:'b' put:badV }.catch:{ |e| 'caught' } } equalTo:'caught';
        var st = Set.of:String;
        st.add:'hi';
        .is:{ st.elementType } equalTo:#String;
        .is:{ { st.add:3 }.catch:{ |e| 'caught' } } equalTo:'caught';
    };

    "* Tag-aware multimethods: exact tag match beats the bare variant; untagged
    "* falls to bare. Cycled through ONE call site so the dispatch caches must
    "* stay correct across tag shapes.
    .test:
    tagDispatchSelectsByTag -> {
        var a = #(1 2).ensure:Integer;
        var b = #('x').ensure:String;
        var c = #(1 2);
        var out = #();
        #(a b c a b c).each:{ |l| out.add:(RenderG.show:l) };
        .is:{ out.at:0 } equalTo:'ints';
        .is:{ out.at:1 } equalTo:'strings';
        .is:{ out.at:2 } equalTo:'plain';
        .is:{ out.at:3 } equalTo:'ints';
        .is:{ out.at:4 } equalTo:'strings';
        .is:{ out.at:5 } equalTo:'plain';
    };

    "* User-class tags use the dispatch parent/mixin walk: List(ShapeG)
    "* accepts a subclass instance and rejects unrelated values.
    .test:
    userClassTagsWalkTheHierarchy -> {
        var shapes = List.of:ShapeG;
        shapes.add:CircleG.new;
        "element reads are honestly T? - narrow before dereferencing"
        var s = shapes.at:0;
        .is:{ s.defined?.if:{ s.area } else:{ 0 } } equalTo:314;
        var notShape = #(5).at:0;
        .is:{ { shapes.add:notShape }.catch:{ |e| 'caught' } } equalTo:'caught';
    };

    "* The insertion error is the house-style TypeError, naming the container
    "* shape, the expected tag, and what arrived.
    .test:
    insertionErrorMessage -> {
        var badX = #('x').at:0;
        var msg = { (List.of:Integer).add:badX }.catch:{ |e| e.message };
        .is:{ msg } equalTo:'List(Integer): element must be Integer, got String';
    };

    "* G2: element-preserving combinators keep the tag (the collector/
    "* emptyLike species protocol); transforming ones are honestly untagged.
    .test:
    combinatorsPreserveTags -> {
        var xs: List(Integer) = #(3 1 2);
        .is:{ (xs.select:{ |x| x > 1 }).elementType } equalTo:#Integer;
        .is:{ (xs.reject:{ |x| x > 1 }).elementType } equalTo:#Integer;
        .is:{ (xs.take:2).elementType } equalTo:#Integer;
        .is:{ (xs.drop:1).elementType } equalTo:#Integer;
        .is:{ xs.reverse.elementType } equalTo:#Integer;
        .is:{ xs.uniq.elementType } equalTo:#Integer;
        .is:{ xs.sort.elementType } equalTo:#Integer;
        .is:{ xs.sort.at:0 } equalTo:1;
        "collect:'s elements are whatever the block returns - untagged"
        .is:{ (xs.collect:{ |x| x * 2 }).elementType } equalTo:nil;
    };

    .test:
    setAlgebraPreservesTags -> {
        var a = Set.of:String;
        a.add:'x';
        var b = Set.of:String;
        b.add:'y';
        .is:{ (a.union:b).elementType } equalTo:#String;
        .is:{ (a.union:b).count } equalTo:2;
        .is:{ (a.intersection:b).elementType } equalTo:#String;
        .is:{ (a.difference:b).elementType } equalTo:#String;
        "a Set's list-shaped combinator results carry the element tag too"
        .is:{ (a.select:{ true }).elementType } equalTo:#String;
    };

    .test:
    emptyLikeCarriesShapeAndTag -> {
        var xs: List(Integer) = #(1);
        .is:{ xs.emptyLike.elementType } equalTo:#Integer;
        .is:{ xs.emptyLike.count } equalTo:0;
        .is:{ #(1).emptyLike.elementType } equalTo:nil;
        var m = Map.of:Integer;
        .is:{ m.emptyLike.elementType } equalTo:#Integer;
        var st = Set.of:String;
        .is:{ st.emptyLike.elementType } equalTo:#String;
    };

    "* Variant identity: same base AND same tags = a true redefinition (the
    "* later definition wins); differing tags coexist as multimethod variants.
    .test:
    sameTagsRedefine -> {
        RedefG <- {
            .meta <-- {
                v: -> { |xs: List(Integer)| 'first' };
                v: -> { |xs: List(Integer)| 'second' }
            }
        };
        .is:{ RedefG.v:(#(1).ensure:Integer) } equalTo:'second';
    };

    "* G4: Block(args ^Ret) erases fully at dispatch - a shaped Block param
    "* accepts ANY block (shapes are checker beliefs; value: checks nothing),
    "* while still constraining against non-block arguments.
    .test:
    blockTypesEraseAtDispatch -> {
        BlockEraseG <- {
            .meta <-- {
                call: -> { |b: Block(Integer ^Boolean)| 'block' };
                call: -> { |x: Integer| 'int' }
            }
        };
        .is:{ BlockEraseG.call:{ |s| s } } equalTo:'block';
        .is:{ BlockEraseG.call:3 } equalTo:'int';
    };

    "* Unlike element tags, block shapes are NOT variant identity: the runtime
    "* cannot tell Block(Integer ^Boolean) from Block(String ^String), so two
    "* signatures differing only in block shape REDEFINE (the later wins) -
    "* never two variants distinguished by something dispatch can't check.
    .test:
    blockShapesRedefine -> {
        BlockRedefG <- {
            .meta <-- {
                v: -> { |b: Block(Integer ^Boolean)| 'first' };
                v: -> { |b: Block(String ^String)| 'second' }
            }
        };
        .is:{ BlockRedefG.v:{ |x| x } } equalTo:'second';
    };
}
