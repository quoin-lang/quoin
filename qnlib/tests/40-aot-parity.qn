"* AOT parity (docs/AOT_ARCH.md): this file must pass identically with and
"* without `QN_AOT=1`. `AotSpin` is a v0 compile candidate (sealed, all-scalar
"* params/returns), so under AOT these methods run as native code — asserting
"* that arithmetic results, error identity (division by zero), scheduling
"* order (run-to-block), and cancellation of a compute-wedged task are
"* indistinguishable from the interpreter.

AotSpin <- {
    .meta <-- {
        spin: -> { |n: Integer ^Integer|
            var i = 0;
            { i < n }.whileDo:{ i = i + 1 };
            i
        };

        fib: -> { |n: Integer ^Integer|
            (n <= 1).if:{ ^n } else:{ ^(.fib:(n - 1)) + (.fib:(n - 2)) }
        };

        div:by: -> { |a: Integer b: Integer ^Integer| a / b }
    };
    .sealed!
};

(TestSuite.new:{ var name = 'AotParity' }).add:{
    .test:scalarResultsMatchInterpreter -> {
        .is:{ AotSpin.fib:20 } equalTo:6765;
        .is:{ AotSpin.spin:100000 } equalTo:100000;
        .is:{ AotSpin.div:7 by:-2 } equalTo:-3
    };

    "* Division by zero raises the same catchable ArithmeticError in native
    "* code as in the interpreter (same message, same catchability).
    .test:divisionByZeroIsCatchable -> {
        .is:{ ({ AotSpin.div:1 by:0 }.catch:{ |e| e.message }) } equalTo:'Division by zero'
    };

    "* A task cancelled while queued dies at its first checkpoint even when its
    "* body is a compiled loop that would otherwise spin for hours — the fuel
    "* checkpoint delivers cancellation exactly like the interpreter's
    "* per-instruction check (coarser granularity, same contract).
    .test:cancelledCompiledLoopDiesAtFirstCheckpoint -> {
        var t = Task.spawn:{ AotSpin.spin:100000000000 };
        t.cancel;
        .is:{ { t.join; 'joined' }.catch:{ |e| 'cancelled' } } equalTo:'cancelled'
    }
};

"* v0.2 shapes: slot-window frames — object params/locals, list ops, string
"* constants, and outcalls (dynamic sends leaving the compiled world through
"* the native re-entry machinery). AotHelper stays unsealed on purpose: every
"* call to it from AotLists is an outcall into interpreted code.

AotHelper <- {
    .meta <-- {
        twice: -> { |x| x * 2 };
        explode: -> { |x| 'kaboom'.throw }
    }
};

AotLists <- {
    .meta <-- {
        buildTo: -> { |n: Integer ^List|
            var l = #();
            var i = 0;
            { i < n }.whileDo:{ l.add:(i * 3); i = i + 1 };
            l
        };

        sum:count: -> { |l: List n: Integer ^Integer|
            var total = 0;
            var i = 0;
            { i < n }.whileDo:{ total = total + (l.at:i); i = i + 1 };
            total
        };

        describe: -> { |x: Integer ^String| 'value: ' + (AotHelper.twice:x) };

        boom: -> { |x: Integer ^Integer| AotHelper.explode:x };

        writeOob: -> { |l: List ^Integer| l.at:99 put:5; 0 }
    };
    .sealed!
};

(TestSuite.new:{ var name = 'AotParityV2' }).add:{
    .test:listBuildAndReadBack -> {
        .is:{ (AotLists.buildTo:5).at:3 } equalTo:9;
        .is:{ (AotLists.buildTo:0).count } equalTo:0
    };

    "* Per-element dynamic sends: the accumulator narrows outcall results back
    "* into a scalar local, checked.
    .test:sumThroughOutcalls -> {
        .is:{ AotLists.sum:(AotLists.buildTo:100) count:100 } equalTo:14850
    };

    "* String constants + cross-class outcalls to interpreted code.
    .test:stringsAndCrossClassCalls -> { .is:{ AotLists.describe:21 } equalTo:'value: 42' };

    "* A thrown Quoin VALUE crosses a compiled frame intact (QuoinError::Thrown
    "* + the rooted active-exception slot — the native-boundary contract).
    .test:thrownValueCrossesCompiledFrame -> {
        .is:{ { AotLists.boom:1 }.catch:{ |e| e } } equalTo:'kaboom'
    };

    "* devirt_ops IndexError semantics through the compiled ListSet helper.
    .test:indexErrorFromCompiledListSet -> {
        .is:{ { AotLists.writeOob:(AotLists.buildTo:3) }.catch:{ |e| 'caught' } } equalTo:'caught'
    }
};

"* Checked-generics enforcement holds INSIDE compiled code: the AOT ListPush/
"* ListSet helpers gate on the tag exactly like the interpreter arms, and the
"* error crosses the compiled frame as a catchable TypeError.

AotGenerics <- {
    .meta <-- {
        fillInto:count: -> { |l: List n: Integer ^Integer|
            var i = 0;
            { i < n }.whileDo:{ l.add:i; i = i + 1 };
            i
        }
    };
    .sealed!
};

(TestSuite.new:{ var name = 'AotParityGenerics' }).add:{
    .test:
    compiledPushRespectsTags -> {
        "an Integer-tagged destination accepts the compiled fill"
        .is:{ AotGenerics.fillInto:(List.of:Integer) count:4 } equalTo:4;
        "a String-tagged destination rejects it, catchably, in BOTH modes"
        .is:{ { AotGenerics.fillInto:(List.of:String) count:4 }.catch:{ |e| 'caught' } }
            equalTo:'caught';
    };
};

"* G3: the proven Boolean?-if lowering. A checked List(Boolean) element read
"* feeding if: compiles to a direct branch with a nil->MNU stub (no capturing
"* cold path). The nil case must raise the EXACT interpreter MNU, catchable,
"* identical in both modes.

AotNilIf <- {
    .meta <-- {
        flagAt: -> { |n: Integer ^Integer|
            var flags: List(Boolean) = #();
            flags.add:true;
            flags.add:false;
            (flags.at:n).if:{ ^^1 };
            0
        }
    };
    .sealed!
};

(TestSuite.new:{ var name = 'AotParityNilIf' }).add:{
    .test:provenBoolIfBranches -> {
        .is:{ AotNilIf.flagAt:0 } equalTo:1;
        .is:{ AotNilIf.flagAt:1 } equalTo:0
    };

    .test:outOfBoundsNilRaisesTheExactMnu -> {
        var m = { AotNilIf.flagAt:99 }.catch:{ |e| e.message };
        .is:{ m } equalTo:'no method \'if:\' for Nil'
    }
};

"* B1 (docs/BLOCK_AOT_ARCH.md): fused each: loops. The literal block is spliced
"* into the method frame behind a native-List guard - no closure, no per-element
"* frame. Semantics pinned in both modes: captured-local mutation, ^^ escape,
"* zero-param bodies, the stale loop bound, the cold path (a non-List receiver
"* dispatches its own each:), and Iterate combinators riding the fused loops.

AotFusedEach <- {
    .meta <-- {
        sumOf: -> { |xs: List ^Integer|
            var sum = 0;
            xs.each:{ |x: Integer| sum = sum + x };
            ^sum
        };
        sumTagged: -> { |xs: List(Integer) ^Integer|
            var sum = 0;
            xs.each:{ |x: Integer| sum = sum + x };
            ^sum
        };
        firstOver:limit: -> { |xs: List n: Integer ^Integer|
            xs.each:{ |x: Integer| (x > n).if:{ ^^x } };
            ^0 - 1
        }
    };
    .sealed!
};

CustomEachG <- {
    each: -> { |b| b.valueWithSelfOrArg:'custom-elem'; b.valueWithSelfOrArg:'custom-elem' }
};

(TestSuite.new:{ var name = 'AotParityFusedEach' }).add:{
    .test:fusedSumBothParamShapes -> {
        var data = #(1 2 3 4 5);
        .is:{ AotFusedEach.sumOf:data } equalTo:15;
        .is:{ AotFusedEach.sumTagged:(data.ensure:Integer) } equalTo:15;
    };

    .test:nonLocalReturnEscapesTheFusedLoop -> {
        .is:{ AotFusedEach.firstOver:#(1 5 2) limit:3 } equalTo:5;
        .is:{ AotFusedEach.firstOver:#(1 2) limit:3 } equalTo:(0 - 1);
    };

    .test:zeroParamBodyAndValue -> {
        var n = 0;
        var r = #(1 2 3).each:{ n = n + 1 };
        .is:{ n } equalTo:3;
        "each: evaluates to nil, fused or not"
        .is:{ r } equalTo:nil;
    };

    .test:mutationSeesTheStaleBoundAndFreshElements -> {
        var xs = #(1 2 3);
        var seen = #();
        xs.each:{ |x| seen.add:x; xs.add:99 };
        .is:{ seen.count } equalTo:3;
        .is:{ xs.count } equalTo:6;
    };

    .test:coldPathDispatchesACustomEach -> {
        "a List-BELIEVED var holding a non-list at runtime takes the guard's
        cold path - the real dispatch, reaching the custom each:"
        var xs: List = #();
        xs = (#(CustomEachG.new).at:0);
        var got = #();
        xs.each:{ |v| got.add:v };
        .is:{ got.count } equalTo:2;
        .is:{ got.at:0 } equalTo:'custom-elem';
    };

    .test:nilElementsFlowThroughTheFusedLoop -> {
        var xs = #(1);
        xs.add:nil;
        xs.add:3;
        var count = 0;
        var nils = 0;
        xs.each:{ |x| count = count + 1; x.defined?.else:{ nils = nils + 1 } };
        .is:{ count } equalTo:3;
        .is:{ nils } equalTo:1;
    };

    .test:nestedFusedLoops -> {
        var total = 0;
        #(1 2).each:{ |a| #(10 20).each:{ |b| total = total + (a * b) } };
        .is:{ total } equalTo:90;
    };

    .test:combinatorsRideTheFusedLoops -> {
        "Iterate's collect:/select: call .each: on self - the guard sends
        native lists down the fused loop inside the combinator bodies"
        var xs: List(Integer) = #(1 2 3 4);
        .is:{ (xs.collect:{ |x| x * 2 }).at:3 } equalTo:8;
        .is:{ (xs.select:{ |x| x > 2 }).count } equalTo:2;
        .is:{ xs.detect:{ |x| x > 2 } } equalTo:3;
        .is:{ xs.reduce:{ |a b| a + b } into:100 } equalTo:110;
    }
};

"* B2: compiled Iterate combinator bodies (open-owner candidacy). The soundness
"* crux: an open class's compiled entries are minted per-dispatch from the
"* method's own template, so a reopen simply dispatches to its new template -
"* and non-List receivers Bail to the interpreted body at entry (whose guarded
"* loop performs the real each: send).

(TestSuite.new:{ var name = 'AotParityOpenOwner' }).add:{
    .test:nonListReceiversBailToTheInterpretedBody -> {
        "Range mixes Iterate but is no native List - the compiled collect:
        must Bail at entry and the interpreted body must agree"
        var viaRange = (1..4).collect:{ |x| x * 10 };
        .is:{ viaRange.count } equalTo:3;
        .is:{ viaRange.at:0 } equalTo:10;
        .is:{ viaRange.at:2 } equalTo:30;
    };

    .test:reopeningIterateInvalidatesCompiledEntries -> {
        "redefine collect: AFTER qnlib loaded (and after its body compiled):
        the new template must win for every collection from here on"
        "same dispatch signature (Block-hinted param) = a TRUE redefinition;
        an untyped param would APPEND a weaker multimethod variant instead"
        Iterate <-- {
            collect: -> { |b: Block| 'redefined' }
        };
        .is:{ #(1 2 3).collect:{ |x| x } } equalTo:'redefined';
        "restore the real collect: so later suites keep working"
        Iterate <-- {
            collect: -> { |collectBlock: Block(T ^U) ^List(U)|
                var l = #();
                .each:{ |collectItem| l.add:collectBlock.valueWithSelfOrArg:collectItem };
                ^l
            }
        };
        .is:{ (#(1 2).collect:{ |x| x + 1 }).at:1 } equalTo:3;
    }
};

"* B3a: compiled block templates. Blocks invoked via valueWithSelfOrArg: run
"* natively when the registry has an entry - and NEVER inside a user Fiber
"* (forced unwind on fiber teardown cannot cross compiled frames, so entry
"* Bails to the interpreted body there). The abandoned-generator shape below
"* is the exact abort repro: a lazy pipeline suspended mid-iteration, then
"* dropped by take:.

(TestSuite.new:{ var name = 'AotParityBlockTemplates' }).add:{
    .test:abandonedGeneratorWithCompiledBlocks -> {
        var lazy = (1..100).lazyCollect:{ |x| x * 3 };
        var got = lazy.take:4;
        .is:{ got.count } equalTo:4;
        .is:{ got.at:3 } equalTo:12;
    };

    .test:capturedCellWritesAreShared -> {
        "a compiled template's free-variable write mutates the SAME cell the
        enclosing frame reads (env_set through the closure chain)"
        var sum = 0;
        var addTo = { |x| sum = sum + x };
        #(1 2 3).each:addTo;
        .is:{ sum } equalTo:6;
        sum = 100;
        addTo.valueWithSelfOrArg:5;
        .is:{ sum } equalTo:105;
    };

    .test:throwingCompiledBlockPropagatesCatchably -> {
        var caught = { #(1).collect:{ |x| Math.ln:0 } }.catch:{ |e| 'caught' };
        .is:{ caught } equalTo:'caught';
    }
}
