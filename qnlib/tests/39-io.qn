"* MARKER:io-coverage-39 — the first line of this file is read back by the stringStream/byteStream
"* cases below; keep it stable. Coverage for the [IO]File / [IO]Folder / [IO]Handle native classes
"* (src/runtime/io.rs). Network-free: it opens this very file and the qnlib/tests/ directory — both
"* stable repo paths (cwd = repo root under `qn test`), so the suite depends on nothing external.

(TestSuite.new:{ name = 'IO' }).add:{
    "* ---- [IO]File: metadata --------------------------------------------------
    .test:
    fileMetadata -> {
        f = [IO]File.open:'qnlib/tests/39-io.qn';
        .is:{ f.fullpath } equalTo:'qnlib/tests/39-io.qn';
        .is:{ f.s } equalTo:'qnlib/tests/39-io.qn';
        .is:{ f.name } equalTo:'39-io.qn';
        .is:{ f.ext } equalTo:'qn';
        .isTrue:{ f.is_file? };
    };

    .test:
    fileEquality -> {
        f = [IO]File.open:'qnlib/tests/39-io.qn';
        .isTrue:{ f == ([IO]File.open:'qnlib/tests/39-io.qn') };
        .isFalse:{ f == ([IO]File.open:'qnlib/main.qn') };
        "* rhs is not an [IO]File -> the native ==: falls through to false
        .isFalse:{ f == [IO]Stdout };
    };

    .test:
    fileOpenMissingThrows -> {
        caught = nil;
        { [IO]File.open:'no/such/file.xyz' }.catch:{ |e| caught = e };
        .isTrue:{ caught.defined? };
    };

    "* ---- [IO]File: streams (read-only; the file is not consumed) -------------
    .test:
    fileStringStreamReadsOwnHeader -> {
        f = [IO]File.open:'qnlib/tests/39-io.qn';
        line = f.stringStream.readLine;
        .isTrue:{ line.contains?:'MARKER:io-coverage-39' };
    };

    .test:
    fileByteStreamReadsAll -> {
        f = [IO]File.open:'qnlib/tests/39-io.qn';
        content = f.byteStream.readAll.asString;
        .isTrue:{ content.contains?:'MARKER:io-coverage-39' };
    };

    "* ---- [IO]Folder: cursor + Iterate mixin ----------------------------------
    .test:
    folderPathAndIteration -> {
        folder = [IO]Folder.open:'qnlib/tests/';
        .is:{ folder.path } equalTo:'qnlib/tests/';
        "* collect:/detect: drive the native each: (next + reset) under the hood
        .isTrue:{ (folder.detect:{ |entry| entry.name == '39-io.qn' }).defined? };
        .isTrue:{ folder.count > 0 };
    };

    .test:
    folderNextAndReset -> {
        folder = [IO]Folder.open:'qnlib/tests/';
        "* directory order is OS-dependent, so only assert a file is yielded
        first = folder.next;
        .isTrue:{ first.defined? };
        .isTrue:{ first.name.defined? };
        folder.reset;
        .isTrue:{ (folder.next).defined? };
    };

    .test:
    folderEquality -> {
        a = [IO]Folder.open:'qnlib/tests/';
        .isTrue:{ a == ([IO]Folder.open:'qnlib/tests/') };
        .isFalse:{ a == ([IO]Folder.open:'qnlib/') };
        .isFalse:{ a == [IO]Stdout };
    };

    "* ---- [IO]Handle: identity + writes ---------------------------------------
    .test:
    handleStringForm -> {
        .is:{ [IO]Stdout.s } equalTo:'[IO]Handle.stdout';
        .is:{ [IO]Stderr.s } equalTo:'[IO]Handle.stderr';
        .is:{ ([IO]Handle.stdin).s } equalTo:'[IO]Handle.stdin';
    };

    .test:
    handleEquality -> {
        .isTrue:{ [IO]Stdout == [IO]Stdout };
        .isTrue:{ ([IO]Handle.stdin) == ([IO]Handle.stdin) };
        .isFalse:{ [IO]Stdout == [IO]Stderr };
        .isFalse:{ [IO]Stderr == [IO]Stdout };
        "* rhs is not a handle (an [IO]File) -> false
        .isFalse:{ [IO]Stdout == ([IO]File.open:'qnlib/tests/39-io.qn') };
    };

    .test:
    handleWriteReturnsNil -> {
        "* write to stderr (keeps the reporter's stdout clean); empty payload = no visible noise
        .is:{ [IO]Stderr.write:'' } equalTo:nil;
        .is:{ [IO]Stderr.writeln:'' } equalTo:nil;
    };

    .test:
    handleWriteNonStringThrows -> {
        caught = nil;
        { [IO]Stderr.write:42 }.catch:{ |e| caught = e };
        .isTrue:{ caught.defined? };
    };

    .test:
    handleWriteToStdinThrows -> {
        c1 = nil;
        c2 = nil;
        { ([IO]Handle.stdin).write:'x' }.catch:{ |e| c1 = e };
        { ([IO]Handle.stdin).writeln:'x' }.catch:{ |e| c2 = e };
        .isTrue:{ c1.defined? };
        .isTrue:{ c2.defined? };
    };
};
