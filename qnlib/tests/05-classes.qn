(TestSuite.new:{ var name = 'Classes' }).add:{
    .test:
    operatorNew -> {
        TSCNC_Constant <- 42;

        .does:{ TSCNC1 <- {} } resultIn:{ TSCNC1.class == Class };
        .does:{ TSCNC1 <- TSCNC2 <- {} } resultIn:{ TSCNC2.parent == TSCNC1 };
        .does:{ Abc <- TSCNC3 <- {} } throw:'Parent class Abc not found';
        .does:{ TSCNC_Constant <- TSCNC3 <- {} } throw:'Parent TSCNC_Constant is not a Class';
    };

    .test:
    operatorNewReturnsClass -> {
        var newClass = nil;
        .does:{ newClass = TSCNC4 <- {} } resultIn:{ newClass == TSCNC4 };
    };

    .test:
    operatorExtend -> {
        "* <-- adds methods to a (non-sealed) user class.
        .is:{ TSCNC1 <-- { abc -> { 'Hi' } }; TSCNC1.new.abc } equalTo:'Hi';
        "* Numeric value types are sealed (see prelude.qn) — adding a method to one throws.
        "* Extending a sealed type throws a typed ClassError (BUGS.md Finding 12).
        .does:{ 42.class <-- { abc -> { 'Hi' } } } throw:ClassError;
    };

    .test:
    operatorExtendReturnsLHS -> {
        .is:{ TSCNC1 <-- {} } equalTo:TSCNC1;
        "* An empty extension mutates nothing, so it returns the LHS even for a sealed type.
        .is:{ 42 <-- {} } equalTo:42;
    };

    .test:
    runsInit -> {
        .is:{
            TSCNC5 <- { |@d|
                init -> { @d = 77 }
                d -> { @d }
            };
            TSCNC5.new.d
        } equalTo:77;
    };

    .test:
    runsBlockInit -> {
        .is:{
            TSCNC6 <- { |@d|
                init: -> {|a b c| @d = a+b+c }
                d -> { @d }
            };
            (TSCNC6.new: { var a = 10; var b = 20; var c = 30 }).d
        } equalTo:60;
    };

    .test:
    runsAncestorInitOnBlockInit -> {
        "* `new:` must still run an ancestor's `init`, even when the subclass
        "* defines `init:`. Each class's initializer pulls the block fields it
        "* names; the subclass need not redeclare the parent's params.
        .is:{
            TSCNC_AB <- { |@x|
                init -> { @x = 100 }
                x -> { @x }
            };
            TSCNC_AB <- TSCNC_ABSub <- { |@y|
                init: -> { |y| @y = y }
                y -> { @y }
            };
            var o = TSCNC_ABSub.new: { var y = 5 };
            #( o.x o.y )
        } equalTo:#( 100 5 );
    };

    .test:
    runsMixinInitOnBlockInit -> {
        "* Same rule for a mixin's `init` when the class defines `init:`.
        .is:{
            TSCNC_MixI <- { |@m|
                init -> { @m = 9 }
                m -> { @m }
            };
            TSCNC_MixSub <- { |@y|
                .mix:TSCNC_MixI;
                init: -> { |y| @y = y }
                y -> { @y }
            };
            var o = TSCNC_MixSub.new: { var y = 7 };
            #( o.m o.y )
        } equalTo:#( 9 7 );
    };

    .test:
    blockInitRequiresExplicitAssignment -> {
        "* An empty `new:{}` must NOT capture a same-named variable from the
        "* surrounding scope; only explicit assignment binds a field. The RHS of
        "* an assignment still resolves up the lexical chain, and the assignment
        "* does not mutate the enclosing variable.
        TSCNC_Cap <- { |@a|
            a -> { @a }
        };
        var a = 42;
        .is:{ (TSCNC_Cap.new:{}).a.defined? } equalTo:false;
        .is:{ (TSCNC_Cap.new:{ a = a }).a } equalTo:42;
        .does:{ TSCNC_Cap.new:{ a = 99 } } resultIn:{ a == 42 };
    };

    .test:
    mixins -> {
        .is:{
            TSCNC7 <- { |@a @b|
                init -> { @a = 1; @b = 2 }
                m -> { @a }
                b -> { @b }
                z -> { @c }
            }

            TSCNC8 <- { |@b @c|
                .mix:TSCNC7;

                init -> {
                    @b = 11;
                    @c = 22
                }

                b -> { @b }
                c -> { #( @a @b @c ) }
            }

            var newObj = TSCNC8.new;
            #( newObj.c newObj.m newObj.z newObj.b )
        } equalTo:#( #( 1 11 22 ) 1 22 11 );
    };

    .test:
    mixinRequirements -> {
        "* A mixin can declare requirements via a class-side assertMeetsRequirements:.
        "* It runs at the END of the host's definition block (so required methods may
        "* be defined after the `.mix:`), and if it throws the host is never registered.
        Mixin <- TSCNC_Req <- {
            .meta <-- {
                assertMeetsRequirements: -> { |class:Class|
                    (class.can?:#req).else:{ ('% needs #req' % class.name).throw }
                }
            }
        };
        "* Host provides #req (defined after the mix) -> defines fine.
        .is:{
            TSCNC_ReqGood <- { .mix:TSCNC_Req; req -> { 7 } };
            TSCNC_ReqGood.new.req
        } equalTo:7;
        "* Host missing #req -> throws at definition time...
        .does:{ TSCNC_ReqBad <- { .mix:TSCNC_Req } } throw:'TSCNC_ReqBad needs #req';
        "* ...and the failed class is not registered. Asked by name: reading `TSCNC_ReqBad`
        "* would raise a NameError, since nothing is bound to it.
        .is:{ Class.exists?:#TSCNC_ReqBad } equalTo:false;
        .is:{ Class.exists?:#TSCNC_ReqGood } equalTo:true;
    };

    .test:
    lateMixInvalidatesCaches -> {
        "* Mixing into a class AFTER it has dispatched and instantiated must
        "* invalidate every cache: memoized resolutions, inline caches, and
        "* the instantiation plan. (mix: previously invalidated nothing — a
        "* mixin shadowing a PARENT's method left stale resolutions.)
        TSCNC_LateParent <- { greet -> { ^'parent' } };
        TSCNC_LateParent <- TSCNC_LateHost <- {};
        var before = TSCNC_LateHost.new;
        "* warm the caches through the parent's method and the init plan
        .is:{ before.greet } equalTo:'parent';
        .is:{ before.greet } equalTo:'parent';
        Mixin <- TSCNC_LateShadow <- { |@stamped|
            greet -> { ^'mixin' };
            init -> { @stamped = 99 };
            stamped -> { ^@stamped }
        };
        TSCNC_LateHost.mix:TSCNC_LateShadow;
        "* dispatch sees the mixin immediately (was stale before the fix)...
        .is:{ TSCNC_LateHost.new.greet } equalTo:'mixin';
        "* ...and the rebuilt instantiation plan runs the mixin's init.
        .is:{ TSCNC_LateHost.new.stamped } equalTo:99;
    };

    .test:
    configAssignmentsBindLocally -> {
        "* A `new:{...}` config block's assignments are the field-binding
        "* DSL: they bind INTO THE BLOCK'S OWN frame, never the enclosing
        "* one — statically, however the block is invoked (E). The enclosing
        "* binding is readable on the RHS and untouched by the LHS.
        var probe = 5;
        TSCNC_CfgProbe <- { |@probe| v -> { ^@probe } };
        var made = TSCNC_CfgProbe.new:{ probe = probe * 10 };
        .is:{ made.v } equalTo:50;
        .is:{ probe } equalTo:5;
        "* A user-defined `new:` that runs the config block as a plain
        "* closure gets the SAME local-binding semantics (previously the
        "* write chain-walked into the enclosing frame — caller-dependent).
        TSCNC_EvilNew <- {
            .meta <-- { new: -> { |blk| blk.value; ^'evil' } }
        };
        var item = 7;
        .is:{ TSCNC_EvilNew.new:{ item = 42 } } equalTo:'evil';
        .is:{ item } equalTo:7;
    };

    "* M2 fused instantiation (docs/MATERIALIZATION_ARCH.md): a plain-config
    "* `new:{ f=e; ... }` compiles to a guarded inline path - these pin that the
    "* hot path, the cold fallbacks, and the refused shapes all behave exactly
    "* as the classic config-frame path.
    .test:
    fusedInstantiationBindsFields -> {
        TSFI_Node <- { |@a @b @c|
            a -> { ^@a };
            b -> { ^@b };
            c -> { ^@c }
        };
        var x = 5;
        var n = TSFI_Node.new:{ a = x * 2; b = 'hi'; c = #(1 2 3) };
        .is:{ n.a } equalTo:10;
        .is:{ n.b } equalTo:'hi';
        .is:{ (n.c).count } equalTo:3;
        "* empty config; unknown names silently dropped; duplicate stores last-wins.
        .is:{ (TSFI_Node.new:{ }).a } equalTo:nil;
        .is:{ (TSFI_Node.new:{ zz = 9; a = 3 }).a } equalTo:3;
        .is:{ (TSFI_Node.new:{ a = 1; a = 2 }).a } equalTo:2;
    };

    .test:
    fusedInstantiationRunsInitChain -> {
        "* A class with `init` still initializes on the fused path (the plan
        "* is consulted per instantiation, epoch-fresh).
        TSFI_Init <- { |@n @dbl|
            init -> { @dbl = @n * 2 };
            n -> { ^@n };
            dbl -> { ^@dbl }
        };
        var o = TSFI_Init.new:{ n = 21 };
        .is:{ o.n } equalTo:21;
        .is:{ o.dbl } equalTo:42;
        "* ...and `init:` receives the config fields it names.
        TSFI_InitColon <- { |@w @tag|
            init: -> { |w| @tag = 'w=' + w };
            tag -> { ^@tag }
        };
        .is:{ (TSFI_InitColon.new:{ w = 9 }).tag } equalTo:'w=9';
    };

    .test:
    fusedInstantiationColdPaths -> {
        "* A user meta `new:` receives the REAL config closure (the guard sends
        "* the site cold before any field expression evaluates).
        TSFI_Evil <- { .meta <-- { new: -> { |blk| blk.value; ^'evil' } } };
        .is:{ TSFI_Evil.new:{ q = 1 } } equalTo:'evil';
        "* An abstract class errors exactly as the classic path.
        TSFI_Abs <- { .abstract! };
        var caught = 'no';
        { TSFI_Abs.new:{ } }.catch:{ |e| caught = 'yes' };
        .is:{ caught } equalTo:'yes';
        "* A non-class receiver errors exactly as the classic path.
        var caught2 = 'no';
        { 5.new:{ a = 1 } }.catch:{ |e| caught2 = 'yes' };
        .is:{ caught2 } equalTo:'yes';
    };

    .test:
    fusedInstantiationRefusedShapesKeepSemantics -> {
        "* Read-after-store sees the config-local binding (the shape refuses
        "* fusion, keeping the classic frame semantics).
        TSFI_RAS <- { |@a @b| a -> { ^@a }; b -> { ^@b } };
        var a = 1;
        var o = TSFI_RAS.new:{ a = 5; b = a };
        .is:{ o.b } equalTo:5;
        .is:{ a } equalTo:1;
        "* Fields inherited from a parent bind on the fused path (the plan's
        "* ivar slots span the hierarchy).
        TSFI_Parent <- { |@p| p -> { ^@p } };
        TSFI_Parent <- TSFI_Child <- { |@q| q -> { ^@q } };
        var c = TSFI_Child.new:{ p = 1; q = 2 };
        .is:{ c.p } equalTo:1;
        .is:{ c.q } equalTo:2;
    };
}
