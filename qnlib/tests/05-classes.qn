(TestSuite.new:{ var name = 'Classes' }).add:{
    .test:
    operatorNew -> {
        TSCNC_Constant <- 42;

        .does:{ TSCNC1 <- {} } resultIn:{ TSCNC1.class == Class };
        .does:{ TSCNC1 <- TSCNC2 <- {} } resultIn:{ TSCNC2.parent == TSCNC1 };
        .does:{ Abc <- TSCNC3 <- {} } throw:'Parent class Abc not found';
        .does:{ TSCNC_Constant <- TSCNC3 <- {} } throw:'Parent TSCNC_Constant is not a Class';
    };

    .test:
    operatorNewReturnsClass -> {
        var newClass = nil;
        .does:{ newClass = TSCNC4 <- {} } resultIn:{ newClass == TSCNC4 };
    };

    .test:
    operatorExtend -> {
        .is:{ (42.class <-- { abc -> { 'Hi' } }); 42.abc } equalTo:'Hi';
        .is:{ var n = 42; n <-- { inst -> { 'Hi' } }; n.inst; } equalTo:'Hi';
    };

    .test:
    operatorExtendReturnsLHS -> {
        .is:{ TSCNC1 <-- {} } equalTo:TSCNC1;
        .is:{ 42 <-- {} } equalTo:42;
    };

    .test:
    runsInit -> {
        .is:{
            TSCNC5 <- { |@d|
                init -> { @d = 77 }
                d -> { @d }
            };
            TSCNC5.new.d
        } equalTo:77;
    };

    .test:
    runsBlockInit -> {
        .is:{
            TSCNC6 <- { |@d|
                init: -> {|a b c| @d = a+b+c }
                d -> { @d }
            };
            (TSCNC6.new: { var a = 10; var b = 20; var c = 30 }).d
        } equalTo:60;
    };

    .test:
    runsAncestorInitOnBlockInit -> {
        "* `new:` must still run an ancestor's `init`, even when the subclass
        "* defines `init:`. Each class's initializer pulls the block fields it
        "* names; the subclass need not redeclare the parent's params.
        .is:{
            TSCNC_AB <- { |@x|
                init -> { @x = 100 }
                x -> { @x }
            };
            TSCNC_AB <- TSCNC_ABSub <- { |@y|
                init: -> { |y| @y = y }
                y -> { @y }
            };
            var o = TSCNC_ABSub.new: { var y = 5 };
            #( o.x o.y )
        } equalTo:#( 100 5 );
    };

    .test:
    runsMixinInitOnBlockInit -> {
        "* Same rule for a mixin's `init` when the class defines `init:`.
        .is:{
            TSCNC_MixI <- { |@m|
                init -> { @m = 9 }
                m -> { @m }
            };
            TSCNC_MixSub <- { |@y|
                .mix:TSCNC_MixI;
                init: -> { |y| @y = y }
                y -> { @y }
            };
            var o = TSCNC_MixSub.new: { var y = 7 };
            #( o.m o.y )
        } equalTo:#( 9 7 );
    };

    .test:
    blockInitRequiresExplicitAssignment -> {
        "* An empty `new:{}` must NOT capture a same-named variable from the
        "* surrounding scope; only explicit assignment binds a field. The RHS of
        "* an assignment still resolves up the lexical chain, and the assignment
        "* does not mutate the enclosing variable.
        TSCNC_Cap <- { |@a|
            a -> { @a }
        };
        var a = 42;
        .is:{ (TSCNC_Cap.new:{}).a.defined? } equalTo:false;
        .is:{ (TSCNC_Cap.new:{ a = a }).a } equalTo:42;
        .does:{ TSCNC_Cap.new:{ a = 99 } } resultIn:{ a == 42 };
    };

    .test:
    mixins -> {
        .is:{
            TSCNC7 <- { |@a @b|
                init -> { @a = 1; @b = 2 }
                m -> { @a }
                b -> { @b }
                z -> { @c }
            }

            TSCNC8 <- { |@b @c|
                .mix:TSCNC7;

                init -> {
                    @b = 11;
                    @c = 22
                }

                b -> { @b }
                c -> { #( @a @b @c ) }
            }

            var newObj = TSCNC8.new;
            #( newObj.c newObj.m newObj.z newObj.b )
        } equalTo:#( #( 1 11 22 ) 1 22 11 );
    };

    .test:
    mixinRequirements -> {
        "* A mixin can declare requirements via a class-side assertMeetsRequirements:.
        "* It runs at the END of the host's definition block (so required methods may
        "* be defined after the `.mix:`), and if it throws the host is never registered.
        Mixin <- TSCNC_Req <- {
            .meta <-- {
                assertMeetsRequirements: -> { |class:Class|
                    (class.can?:#req).else:{ ('% needs #req' % class.name).throw }
                }
            }
        };
        "* Host provides #req (defined after the mix) -> defines fine.
        .is:{
            TSCNC_ReqGood <- { .mix:TSCNC_Req; req -> { 7 } };
            TSCNC_ReqGood.new.req
        } equalTo:7;
        "* Host missing #req -> throws at definition time...
        .does:{ TSCNC_ReqBad <- { .mix:TSCNC_Req } } throw:'TSCNC_ReqBad needs #req';
        "* ...and the failed class is not registered.
        .is:{ TSCNC_ReqBad.defined? } equalTo:false;
    };
}
