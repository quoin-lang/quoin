"* AOT parity (docs/AOT_ARCH.md): this file must pass identically with and
"* without `QN_AOT=1`. `AotSpin` is a v0 compile candidate (sealed, all-scalar
"* params/returns), so under AOT these methods run as native code — asserting
"* that arithmetic results, error identity (division by zero), scheduling
"* order (run-to-block), and cancellation of a compute-wedged task are
"* indistinguishable from the interpreter.

AotSpin <- {
    .meta <-- {
        spin: -> { |n: Integer ^Integer|
            var i = 0
            { i < n }.whileDo:{ i = i + 1 }
            i
        }

        fib: -> { |n: Integer ^Integer|
            (n <= 1).if:{ ^n } else:{ ^(.fib:(n - 1)) + (.fib:(n - 2)) }
        }

        div:by: -> { |a: Integer b: Integer ^Integer| a / b }
    };
    .sealed!
}

(TestSuite.new:{ var name = 'AotParity' }).add:{
    .test:scalarResultsMatchInterpreter -> {
        .is:{ AotSpin.fib:20 } equalTo:6765;
        .is:{ AotSpin.spin:100000 } equalTo:100000;
        .is:{ AotSpin.div:7 by:-2 } equalTo:-3
    };

    "* Division by zero raises the same catchable ArithmeticError in native
    "* code as in the interpreter (same message, same catchability).
    .test:divisionByZeroIsCatchable -> {
        .is:{ ({ AotSpin.div:1 by:0 }.catch:{ |e| e.message }) } equalTo:'Division by zero'
    };

    "* A task cancelled while queued dies at its first checkpoint even when its
    "* body is a compiled loop that would otherwise spin for hours — the fuel
    "* checkpoint delivers cancellation exactly like the interpreter's
    "* per-instruction check (coarser granularity, same contract).
    .test:cancelledCompiledLoopDiesAtFirstCheckpoint -> {
        var t = Task.spawn:{ AotSpin.spin:100000000000 }
        t.cancel;
        .is:{ { t.join; 'joined' }.catch:{ |e| 'cancelled' } } equalTo:'cancelled'
    }
}

"* v0.2 shapes: slot-window frames — object params/locals, list ops, string
"* constants, and outcalls (dynamic sends leaving the compiled world through
"* the native re-entry machinery). AotHelper stays unsealed on purpose: every
"* call to it from AotLists is an outcall into interpreted code.

AotHelper <- {
    .meta <-- {
        twice: -> { |x| x * 2 }
        explode: -> { |x| 'kaboom'.throw }
    }
}

AotLists <- {
    .meta <-- {
        buildTo: -> { |n: Integer ^List|
            var l = #()
            var i = 0
            { i < n }.whileDo:{ l.add:(i * 3); i = i + 1 }
            l
        }

        sum:count: -> { |l: List n: Integer ^Integer|
            var total = 0
            var i = 0
            { i < n }.whileDo:{ total = total + (l.at:i); i = i + 1 }
            total
        }

        describe: -> { |x: Integer ^String| 'value: ' + (AotHelper.twice:x) }

        boom: -> { |x: Integer ^Integer| AotHelper.explode:x }

        writeOob: -> { |l: List ^Integer| l.at:99 put:5; 0 }
    };
    .sealed!
}

(TestSuite.new:{ var name = 'AotParityV2' }).add:{
    .test:listBuildAndReadBack -> {
        .is:{ (AotLists.buildTo:5).at:3 } equalTo:9;
        .is:{ (AotLists.buildTo:0).count } equalTo:0
    };

    "* Per-element dynamic sends: the accumulator narrows outcall results back
    "* into a scalar local, checked.
    .test:sumThroughOutcalls -> {
        .is:{ AotLists.sum:(AotLists.buildTo:100) count:100 } equalTo:14850
    };

    "* String constants + cross-class outcalls to interpreted code.
    .test:stringsAndCrossClassCalls -> { .is:{ AotLists.describe:21 } equalTo:'value: 42' };

    "* A thrown Quoin VALUE crosses a compiled frame intact (QuoinError::Thrown
    "* + the rooted active-exception slot — the native-boundary contract).
    .test:thrownValueCrossesCompiledFrame -> {
        .is:{ { AotLists.boom:1 }.catch:{ |e| e } } equalTo:'kaboom'
    };

    "* devirt_ops IndexError semantics through the compiled ListSet helper.
    .test:indexErrorFromCompiledListSet -> {
        .is:{ { AotLists.writeOob:(AotLists.buildTo:3) }.catch:{ |e| 'caught' } } equalTo:'caught'
    }
}

"* Checked-generics enforcement holds INSIDE compiled code: the AOT ListPush/
"* ListSet helpers gate on the tag exactly like the interpreter arms, and the
"* error crosses the compiled frame as a catchable TypeError.

AotGenerics <- {
    .meta <-- {
        fillInto:count: -> { |l: List n: Integer ^Integer|
            var i = 0
            { i < n }.whileDo:{ l.add:i; i = i + 1 }
            i
        }
    };
    .sealed!
}

(TestSuite.new:{ var name = 'AotParityGenerics' }).add:{
    .test:
    compiledPushRespectsTags -> {
        "an Integer-tagged destination accepts the compiled fill"
        .is:{ AotGenerics.fillInto:(List.of:Integer) count:4 } equalTo:4;
        "a String-tagged destination rejects it, catchably, in BOTH modes"
        .is:{ { AotGenerics.fillInto:(List.of:String) count:4 }.catch:{ |e| 'caught' } }
            equalTo:'caught';
    };
}

"* G3: the proven Boolean?-if lowering. A checked List(Boolean) element read
"* feeding if: compiles to a direct branch with a nil->MNU stub (no capturing
"* cold path). The nil case must raise the EXACT interpreter MNU, catchable,
"* identical in both modes.

AotNilIf <- {
    .meta <-- {
        flagAt: -> { |n: Integer ^Integer|
            var flags: List(Boolean) = #()
            flags.add:true
            flags.add:false
            (flags.at:n).if:{ ^^1 }  "* allow: nil-receiver (nil->MNU is the point)
            0
        }
    };
    .sealed!
}

(TestSuite.new:{ var name = 'AotParityNilIf' }).add:{
    .test:provenBoolIfBranches -> {
        .is:{ AotNilIf.flagAt:0 } equalTo:1;
        .is:{ AotNilIf.flagAt:1 } equalTo:0
    };

    .test:outOfBoundsNilRaisesTheExactMnu -> {
        var m = { AotNilIf.flagAt:99 }.catch:{ |e| e.message };
        .is:{ m } equalTo:'no method \'if:\' for Nil'
    }
}

"* B1 (docs/BLOCK_AOT_ARCH.md): fused each: loops. The literal block is spliced
"* into the method frame behind a native-List guard - no closure, no per-element
"* frame. Semantics pinned in both modes: captured-local mutation, ^^ escape,
"* zero-param bodies, the stale loop bound, the cold path (a non-List receiver
"* dispatches its own each:), and Iterate combinators riding the fused loops.

AotFusedEach <- {
    .meta <-- {
        sumOf: -> { |xs: List ^Integer|
            var sum = 0
            xs.each:{ |x: Integer| sum = sum + x }
            ^sum
        }
        sumTagged: -> { |xs: List(Integer) ^Integer|
            var sum = 0
            xs.each:{ |x: Integer| sum = sum + x }
            ^sum
        }
        firstOver:limit: -> { |xs: List n: Integer ^Integer|
            xs.each:{ |x: Integer| (x > n).if:{ ^^x } }
            ^0 - 1
        }
    };
    .sealed!
}

CustomEachG <- {
    each: -> { |b| b.valueWithSelfOrArg:'custom-elem'; b.valueWithSelfOrArg:'custom-elem' }
}

(TestSuite.new:{ var name = 'AotParityFusedEach' }).add:{
    .test:fusedSumBothParamShapes -> {
        var data = #(1 2 3 4 5);
        .is:{ AotFusedEach.sumOf:data } equalTo:15;
        .is:{ AotFusedEach.sumTagged:(data.ensure:Integer) } equalTo:15;
    };

    .test:nonLocalReturnEscapesTheFusedLoop -> {
        .is:{ AotFusedEach.firstOver:#(1 5 2) limit:3 } equalTo:5;
        .is:{ AotFusedEach.firstOver:#(1 2) limit:3 } equalTo:(0 - 1);
    };

    .test:zeroParamBodyAndValue -> {
        var n = 0;
        var r = #(1 2 3).each:{ n = n + 1 };
        .is:{ n } equalTo:3;
        "each: evaluates to nil, fused or not"
        .is:{ r } equalTo:nil;
    };

    .test:mutationSeesTheStaleBoundAndFreshElements -> {
        var xs = #(1 2 3);
        var seen = #();
        xs.each:{ |x| seen.add:x; xs.add:99 };
        .is:{ seen.count } equalTo:3;
        .is:{ xs.count } equalTo:6;
    };

    .test:coldPathDispatchesACustomEach -> {
        "a List-BELIEVED var holding a non-list at runtime takes the guard's
        cold path - the real dispatch, reaching the custom each:"
        var xs: List = #();
        xs = (#(CustomEachG.new).at:0);
        var got = #();
        xs.each:{ |v| got.add:v };
        .is:{ got.count } equalTo:2;
        .is:{ got.at:0 } equalTo:'custom-elem';
    };

    .test:paramReassignmentInFusedBody -> {
        "* B1 regression (found by `qn check` on the warnings gallery): a body
        "* reassigning its own param must compile through the splice's
        "* param override — reads AND writes — not trip strict-var.
        var l = #( 1 2 3 );
        var total = 0;
        l.each:{ |x| x = x + 10; total = total + x };
        .is:{ total } equalTo:36;
        .is:{ l.collect:{ |x| x = x * 2; x } } equalTo:#( 2 4 6 );
    };

    .test:nilElementsFlowThroughTheFusedLoop -> {
        var xs = #(1);
        xs.add:nil;
        xs.add:3;
        var count = 0;
        var nils = 0;
        xs.each:{ |x| count = count + 1; x.defined?.else:{ nils = nils + 1 } };
        .is:{ count } equalTo:3;
        .is:{ nils } equalTo:1;
    };

    .test:nestedFusedLoops -> {
        var total = 0;
        #(1 2).each:{ |a| #(10 20).each:{ |b| total = total + (a * b) } };
        .is:{ total } equalTo:90;
    };

    .test:combinatorsRideTheFusedLoops -> {
        "Iterate's collect:/select: call .each: on self - the guard sends
        native lists down the fused loop inside the combinator bodies"
        var xs: List(Integer) = #(1 2 3 4);
        .is:{ (xs.collect:{ |x| x * 2 }).at:3 } equalTo:8;
        .is:{ (xs.select:{ |x| x > 2 }).count } equalTo:2;
        .is:{ xs.detect:{ |x| x > 2 } } equalTo:3;
        .is:{ xs.reduce:{ |a b| a + b } into:100 } equalTo:110;
    }
}

"* B2: compiled Iterate combinator bodies (open-owner candidacy). The soundness
"* crux: an open class's compiled entries are minted per-dispatch from the
"* method's own template, so a reopen simply dispatches to its new template -
"* and non-List receivers Bail to the interpreted body at entry (whose guarded
"* loop performs the real each: send).

(TestSuite.new:{ var name = 'AotParityOpenOwner' }).add:{
    .test:nonListReceiversBailToTheInterpretedBody -> {
        "Range mixes Iterate but is no native List - the compiled collect:
        must Bail at entry and the interpreted body must agree"
        var viaRange = (1..4).collect:{ |x| x * 10 };
        .is:{ viaRange.count } equalTo:3;
        .is:{ viaRange.at:0 } equalTo:10;
        .is:{ viaRange.at:2 } equalTo:30;
    };

    .test:reopeningIterateInvalidatesCompiledEntries -> {
        "redefine collect: AFTER qnlib loaded (and after its body compiled):
        the new template must win for every collection from here on"
        "same dispatch signature (Block-hinted param) = a TRUE redefinition;
        an untyped param would APPEND a weaker multimethod variant instead"
        Iterate <-- {
            collect: -> { |b: Block| 'redefined' }
        };
        .is:{ #(1 2 3).collect:{ |x| x } } equalTo:'redefined';
        "restore the real collect: so later suites keep working"
        Iterate <-- {
            collect: -> { |collectBlock: Block(T ^U) ^List(U)|
                var l = #();
                .each:{ |collectItem| l.add:collectBlock.valueWithSelfOrArg:collectItem };
                ^l
            }
        };
        .is:{ (#(1 2).collect:{ |x| x + 1 }).at:1 } equalTo:3;
    }
}

"* B3a: compiled block templates. Blocks invoked via valueWithSelfOrArg: run
"* natively when the registry has an entry - INCLUDING inside user Fibers
"* (the historical entry bail is gone: an abandoned fiber that ran compiled
"* code leaks its suspended stack via force_reset instead of force-unwinding
"* across Cranelift frames). The abandoned-generator shape below was the
"* exact abort repro: a lazy pipeline suspended mid-iteration, then dropped
"* by take:.

(TestSuite.new:{ var name = 'AotParityBlockTemplates' }).add:{
    .test:abandonedGeneratorWithCompiledBlocks -> {
        var lazy = (1..100).lazyCollect:{ |x| x * 3 };
        var got = lazy.take:4;
        .is:{ got.count } equalTo:4;
        .is:{ got.at:3 } equalTo:12;
    };

    .test:capturedCellWritesAreShared -> {
        "a compiled template's free-variable write mutates the SAME cell the
        enclosing frame reads (env_set through the closure chain)"
        var sum = 0;
        var addTo = { |x| sum = sum + x };
        #(1 2 3).each:addTo;
        .is:{ sum } equalTo:6;
        sum = 100;
        addTo.valueWithSelfOrArg:5;
        .is:{ sum } equalTo:105;
    };

    .test:throwingCompiledBlockPropagatesCatchably -> {
        var caught = { #(1).collect:{ |x| Math.ln:0 } }.catch:{ |e| 'caught' };
        .is:{ caught } equalTo:'caught';
    }
}

"* B3b: cold-path closure materialization. A compiled frame can materialize a
"* real closure (read-only captures, no ^^) over a SNAPSHOT env chained to the
"* invoking frame's enclosing environment - so nested closures resolve free
"* names through the FULL lexical chain (the webapp `path` lesson: a template
"* whose nested literal reads a name from two frames up).

NestedCaptureG <- {
    .meta <-- {
        "* mirrors Route#allowFor:'s shape: outer block over a Map, inner block
        "* reading the METHOD param through both closure layers
        tally:in: -> { |needle table|
            var hits = 0
            table.each:{ |kv| (kv.value.any?:{ |entry| entry == needle }).if:{ hits = hits + 1 } }
            ^hits
        }
    }
}

(TestSuite.new:{ var name = 'AotParityColdBlocks' }).add:{
    .test:nestedClosuresResolveThroughTheFullChain -> {
        var t = #{}
        t.at:'a' put:#( 1 2 )
        t.at:'b' put:#( 2 3 )
        t.at:'c' put:#( 9 );
        .is:{ NestedCaptureG.tally:2 in:t } equalTo:2;
        .is:{ NestedCaptureG.tally:9 in:t } equalTo:1;
        .is:{ NestedCaptureG.tally:0 in:t } equalTo:0
    };

    .test:selectFamilyStaysExact -> {
        var xs: List(Integer) = #( 5 1 4 2 3 );
        .is:{ (xs.select:{ |x| x > 2 }).count } equalTo:3;
        .is:{ (xs.reject:{ |x| x > 2 }).count } equalTo:2;
        .is:{ xs.uniq.count } equalTo:5;
        .is:{ xs.sort.at:0 } equalTo:1
        var thrown = { xs.select:{ |x| (x == 4).if:{ ValueError.throw:'mid' }; true } }.catch:{ |e|
            e.class.name
        };
        .is:{ thrown } equalTo:'ValueError'
    }
}

"* S1 (SPECULATIVE_AOT_ARCH): unannotated methods compile at warmth from their
"* OBSERVED kinds, with entry preconditions that Bail to the interpreter on a
"* kind mismatch - and tombstone after enough consecutive mispredictions.
"* Every shape below crosses the promotion boundary mid-test.

SpecArith <- {
    .meta <-- {
        triple: -> { |x| ^(x * 3) + 1 }
        addBoth:and: -> { |a b: Integer| ^a + b }
        orNil: -> { |v| v.defined?.if:{ ^v } else:{ ^0 } }
    }
}

(TestSuite.new:{ var name = 'AotParitySpeculation' }).add:{
    .test:promotionKeepsResults -> {
        var total = 0;
        var i = 0;
        { i < 40 }.whileDo:{ total = total + (SpecArith.triple:i); i = i + 1 };
        .is:{ total } equalTo:2380;
    };

    .test:kindMismatchBailsExactly -> {
        var warm = 0;
        var i = 0;
        { i < 20 }.whileDo:{ warm = warm + (SpecArith.triple:i); i = i + 1 };
        .is:{ warm } equalTo:590;
        "* the speculation observed Int; Doubles must Bail to the interpreter
        "* and keep exact semantics
        .is:{ SpecArith.triple:1.5 } equalTo:5.5;
        .is:{ SpecArith.triple:2 } equalTo:7;
    };

    .test:tombstoneStaysCorrect -> {
        var i = 0;
        { i < 20 }.whileDo:{ SpecArith.orNil:i; i = i + 1 };
        "* hammer the mispredicted kind past the tombstone threshold
        i = 0;
        var s = '';
        { i < 12 }.whileDo:{ s = SpecArith.orNil:'x'; i = i + 1 };
        .is:{ s } equalTo:'x';
        .is:{ SpecArith.orNil:nil } equalTo:0;
        .is:{ SpecArith.orNil:7 } equalTo:7;
    };

    .test:mixedAnnotationsKeepGuarantees -> {
        var total = 0;
        var i = 0;
        { i < 20 }.whileDo:{ total = total + (SpecArith.addBoth:i and:2); i = i + 1 };
        .is:{ total } equalTo:230;
        .is:{ SpecArith.addBoth:0.5 and:2 } equalTo:2.5;
    }
}

"* S1 seam regressions, each found by promotion sweeping qnlib (docs/
"* SPECULATIVE_AOT_ARCH.md): value-as-real-method, ^^ escaping through a
"* compiled frame whose caller had an empty operand stack, nil-declared vars
"* captured by write-back blocks, and sibling closures sharing written
"* captures (unfused whileDo: refuses compilation and stays interpreted).

SpecSeams <- {
    .meta <-- {
        callIt: -> { |b| ^b.value }
        pick: -> { |v| v.else:{ ^^'from-arm' }; ^'fell-through' }
        recordish: -> { |testBlock|
            var result = nil
            var elapsed = Timer.time:{ result = testBlock.value }
            ^(result == true)
        }
        scan: -> { |s|
            var src = s.asBytes
            var n = src.count
            var i = 0
            var steps = 0
            { i < n }.whileDo:{
                var b = src.at:i
                (b == 37).if:{ i = i + 3 } else:{ i = i + 1 }
                steps = steps + 1
            }
            ^steps
        }
    }
}

(TestSuite.new:{ var name = 'AotParitySpecSeams' }).add:{
    .test:valueDispatchesAsARealMethod -> {
        var total = 0
        var i = 0
        { i < 20 }.whileDo:{ total = total + (SpecSeams.callIt:{ 3 }); i = i + 1 };
        .is:{ total } equalTo:60;
        .is:{ false.else:{ 42 } } equalTo:42
    };

    .test:nonLocalReturnCrossesCompiledFrames -> {
        var i = 0
        var r = ''
        { i < 20 }.whileDo:{ r = SpecSeams.pick:false; i = i + 1 };
        .is:{ r } equalTo:'from-arm';
        .is:{ SpecSeams.pick:true } equalTo:'fell-through'
    };

    .test:nilDeclaredCaptureWritesBack -> {
        var i = 0
        var ok = 0
        { i < 20 }.whileDo:{
            (SpecSeams.recordish:{ 1 < 2 }).if:{ ok = ok + 1 }
            i = i + 1
        };
        .is:{ ok } equalTo:20
    };

    .test:siblingClosuresShareCells -> {
        var i = 0
        var last = 0
        { i < 20 }.whileDo:{ last = SpecSeams.scan:'ab%41cd'; i = i + 1 };
        .is:{ last } equalTo:5
    }
}

"* S2 (SPECULATIVE_AOT_ARCH): observed-scalar RETURNS compile as scalars with
"* epoch-guarded DIRECT SELF-RECURSION for open owners. Redefining any method
"* stales the epoch, so compiled recursion Bails to the interpreter and picks
"* up new definitions exactly.

SpecRec <- {
    .meta <-- {
        fib: -> { |n| (n <= 1).if:{ ^n } else:{ ^(.fib:(n - 1)) + (.fib:(n - 2)) } }
    }
}
SpecRedef <- {
    .meta <-- {
        gen: -> { |n| (n <= 0).if:{ ^0 } else:{ ^1 + (.gen:(n - 1)) } }
    }
}

(TestSuite.new:{ var name = 'AotParitySpecReturns' }).add:{
    .test:recursionCompilesAndStaysExact -> {
        var i = 0;
        var last = 0;
        { i < 12 }.whileDo:{ last = SpecRec.fib:15; i = i + 1 };
        .is:{ last } equalTo:610;
        .is:{ SpecRec.fib:0 } equalTo:0;
        .is:{ SpecRec.fib:1 } equalTo:1;
    };

    .test:redefinitionInvalidatesCompiledRecursion -> {
        var i = 0;
        { i < 12 }.whileDo:{ SpecRedef.gen:10; i = i + 1 };
        .is:{ SpecRedef.gen:10 } equalTo:10;
        "* replace the method mid-run: compiled direct recursion must not
        "* keep running the old body
        SpecRedef <-- { .meta <-- { gen: -> { |n| ^100 + n } } };
        .is:{ SpecRedef.gen:10 } equalTo:110;
    }
}

"* S3 (SPECULATIVE_AOT_ARCH): compiled field access through the interpreter's
"* shared (template_id, ip) field-slot caches. Reads of missing fields are
"* nil, undeclared stores raise the interpreter's exact errors, and a block
"* template reading @fields sees the vWSOA-bound ELEMENT as self - all
"* identical to interpreted semantics.

SpecCell <- { | @v @w |
    init: -> { |v| @v = v; @w = 0 }
    v -> { ^@v }
    bumpW -> { @w = @w + 1; ^@w }
    missing -> { ^@u2 }
    sum -> { ^@v + @w }
}

(TestSuite.new:{ var name = 'AotParityFields' }).add:{
    .test:accessorsCompileAndStayExact -> {
        var c = SpecCell.new:{ var v = 7 }
        var i = 0
        var total = 0
        { i < 20 }.whileDo:{ total = total + c.v + c.bumpW; i = i + 1 };
        .is:{ total } equalTo:350;
        .is:{ c.sum } equalTo:27
    };

    .test:missingFieldReadsNil -> {
        var c = SpecCell.new:{ var v = 1 }
        var i = 0
        { i < 12 }.whileDo:{ c.missing; i = i + 1 };
        .is:{ c.missing } equalTo:nil
    };

    .test:fieldsInsideBlockTemplatesUseElementSelf -> {
        var cells = #()
        var i = 0
        { i < 3 }.whileDo:{ cells.add:(SpecCell.new:{ var v = i }); i = i + 1 }
        var k = 0
        var total = 0
        { k < 15 }.whileDo:{
            total = 0
            cells.each:{ |c| total = total + c.v }
            k = k + 1
        };
        .is:{ total } equalTo:3
    }
}

"* --- S5a: non-local return (^^) from compiled frames --------------------
"* A compiled method has no interpreter frame; a `^^` whose home is a live
"* compiled invocation delivers through its frame mark (vm.aot_frame_marks)
"* and the AOT error channel. These pin the four shapes: a direct cold-arm
"* early exit, stores before the exit, nested compiled frames unwinding to
"* the RIGHT home, and a `^^` passing THROUGH a compiled frame to a home
"* below it.
NlrClassify <- {
    classify: -> { |n|
        (n < 10).if:{ ^^'small' }
        ^'big'
    }
}

NlrTask <- { | @count @hold |
    init: -> { |count| @count = count; @hold = 0 }
    step -> {
        @count = @count - 1
        (@count == 0).if:{ @hold = @hold + 1; ^^'held' }
        ^'ran'
    }
    hold -> { ^@hold }
}

NlrInner <- {
    pick: -> { |n| (n < 0).if:{ ^^'neg' }; ^'pos' }
}

NlrOuter <- {
    combo: -> { |n| var r = NlrInner.new.pick:n; ^'got-' + r }
}

NlrRunner <- {
    run: -> { |b| b.value; ^'not-escaped' }
}

NlrCaller <- {
    tryIt -> {
        var s = 'escaped'
        var blk = { ^^ s }
        var r = NlrRunner.new.run:blk
        ^'after-' + r
    }
}

NlrCatcher <- {
    m -> {
        var v = 'early'
        { ^^ v }.catch:{ |e| 'caught' }
        ^'late'
    }
}

(TestSuite.new:{ var name = 'AotParityNlr' }).add:{
    .test:coldArmReturnsFromTheMethod -> {
        var c = NlrClassify.new;
        var i = 0;
        var acc = '';
        { i < 6 }.whileDo:{ acc = acc + (c.classify:(i * 4)); i = i + 1 };
        .is:{ acc } equalTo:'smallsmallsmallbigbigbig'
    };

    .test:coldArmWithStoresBeforeReturn -> {
        var k = 0;
        var held = 0;
        var acc = '';
        { k < 4 }.whileDo:{
            var t = NlrTask.new:{ var count = 5 };
            var j = 0;
            { j < 5 }.whileDo:{ acc = acc + (t.step); j = j + 1 };
            held = held + t.hold;
            k = k + 1
        };
        .is:{ held } equalTo:4;
        .is:{ acc } equalTo:'ranranranranheldranranranranheldranranranranheldranranranranheld'
    };

    .test:nestedCompiledFramesUnwindToTheRightHome -> {
        var o = NlrOuter.new;
        var i = 0;
        var acc = '';
        { i < 12 }.whileDo:{
            acc = acc + (o.combo:(5 - i)) + ' ';
            i = i + 1
        };
        "* inner's ^^ returns from INNER only — outer always appends its prefix
        .is:{ acc } equalTo:'got-pos got-pos got-pos got-pos got-pos got-pos got-neg got-neg got-neg got-neg got-neg got-neg '
    };

    .test:nlrThroughACompiledFrameToTheHomeBelow -> {
        var c = NlrCaller.new;
        var i = 0;
        var acc = '';
        { i < 12 }.whileDo:{ acc = acc + (c.tryIt) + ' '; i = i + 1 };
        "* the ^^ unwinds THROUGH run:'s frame — tryIt never reaches 'after-'
        .is:{ acc } equalTo:'escaped escaped escaped escaped escaped escaped escaped escaped escaped escaped escaped escaped '
    };

    .test:nlrUnderCatchMatchesInterpreted -> {
        "* interpreted, a catch-all CATCHES a ^^ crossing it — compiled must
        "* match byte-for-byte, which the translation refusal ('non-local
        "* return (^^) under a catch') guarantees. (Before the send-window
        "* rework this pinned 'earlycaught': the pre-window unwind leaked a
        "* stack slot that broke the loop after ONE iteration. The catch now
        "* cleanly yields the handler value every pass, both modes.)
        var t = NlrCatcher.new;
        .is:{ t.m } equalTo:'caught';
        var i = 0;
        var acc = '';
        { i < 5 }.whileDo:{ acc = acc + (t.m); i = i + 1 };
        .is:{ acc } equalTo:'caughtcaughtcaughtcaughtcaught'
    };

    .test:taskInterleavedNlrHomesStayPerTask -> {
        "* two tasks park INSIDE compiled bodies, then ^^ from cold arms —
        "* each must come home to ITS OWN invocation (per-task frame marks).
        var w = NlrWorker.new;
        var i = 0;
        { i < 3 }.whileDo:{ w.work:'warm' sleep:1; i = i + 1 };
        var ta = Task.spawn:{ w.work:'A' sleep:20 };
        var tb = Task.spawn:{ Async.sleep:5; w.work:'B' sleep:40 };
        .is:{ ta.join } equalTo:'ok-A';
        .is:{ tb.join } equalTo:'ok-B'
    }
}

NlrWorker <- {
    work:sleep: -> { |label ms|
        Async.sleep:ms
        (label.length > 0).if:{ ^^'ok-' + label }
        ^'fell-through'
    }
}

"* --- S5b: nested literals in materialized cold arms ----------------------
"* The materialized closure runs interpreted, so nested blocks execute
"* naturally; the gate scan is transitive (free writes -> writebacks, ^^
"* anywhere -> the S5a home machinery, inherited through the closure's
"* frame). HandlerTask#run: (richards) is the motivating shape: a ^^ two
"* arms deep.
NlrHandler <- { | @v1 @v2 |
    init: -> { |v1| @v1 = v1; @v2 = 0 }
    handle: -> { |limit|
        @v1.defined?.if:{
            var have = @v1
            (have < limit).if:{
                (@v2 < 100).if:{
                    @v2 = @v2 + have
                    ^^'queued'
                }
            }
            else:{
                @v1 = nil
                ^^'drained'
            }
        }
        ^'idle'
    }
    v2 -> { ^@v2 }
}

NlrNestWriter <- {
    tally: -> { |n|
        var seen = 0
        (n > 0).if:{ (n > 10).if:{ seen = n * 2 } else:{ seen = n } }
        ^seen
    }
}

(TestSuite.new:{ var name = 'AotParityNlrNested' }).add:{
    .test:nestedArmReturnsThroughTwoLevels -> {
        var acc = '';
        var i = 0;
        { i < 12 }.whileDo:{
            var h = NlrHandler.new:{ var v1 = 5 };
            acc = acc + (h.handle:10) + ' ';
            acc = acc + (h.handle:3) + ' ';
            i = i + 1;
            (i == 12).if:{ acc = acc + h.v2 }
        };
        "* first call: 5 < 10, @v2 0->5, 'queued'; second: 5 >= 3, 'drained'
        .is:{ acc.contains?:'queued drained' } equalTo:true;
        .is:{ acc.contains?:' 5' } equalTo:true
    };

    .test:nestedFreeWritesFlushBack -> {
        var w = NlrNestWriter.new;
        var i = 0;
        var total = 0;
        { i < 15 }.whileDo:{ total = total + (w.tally:i); i = i + 1 };
        "* 1..10 -> n, 11..14 -> 2n : 55 + 2*(11+12+13+14) = 155
        .is:{ total } equalTo:155
    }
}

"* --- tracked-closure escape (R0a) ----------------------------------------
"* A materialized closure with OBLIGATIONS (pending write-backs, or a ^^
"* whose catch-parity gate must see its consumer) must flow directly from
"* materialization to its consuming send: bound to a local first, its
"* obligations would key to a stale SSA value and silently orphan. Both
"* shapes REFUSE (stay interpreted) — these pin the observable parity.
EscWriter <- {
    run: -> { |b| b.value }
    tally -> {
        var total = 0
        var blk = { total = total + 1 };
        .run:blk;
        .run:blk
        ^total
    }
}

EscCatcher <- {
    m -> {
        var v = 'early'
        var p = { ^^ v }
        p.catch:{ |e| 'caught' }
        ^'late'
    }
}

(TestSuite.new:{ var name = 'AotParityEscape' }).add:{
    .test:localBoundWriteCaptureStaysExact -> {
        "* unfixed, the compiled body orphaned the write-back: total stayed 0
        var w = EscWriter.new;
        var i = 0;
        var acc = '';
        { i < 12 }.whileDo:{ acc = acc + (w.tally); i = i + 1 };
        .is:{ acc } equalTo:'222222222222'
    };

    .test:localBoundNlrUnderCatchMatchesInterpreted -> {
        var t = EscCatcher.new;
        var i = 0;
        var acc = '';
        { i < 5 }.whileDo:{ acc = acc + (t.m); i = i + 1 };
        .is:{ acc } equalTo:'caughtcaughtcaughtcaughtcaught'
    }
}

"* Block-argument scalar speculation: a hot one-param block whose observed
"* args are all Integer compiles its param into a register lane, guarded by
"* an entry precondition. Semantics must be invisible: a mid-stream kind
"* change Bails to the interpreted body (and tombstones after enough
"* consecutive misses), a param reassignment stays exact, and results match
"* the interpreter bit-for-bit in both modes.

(TestSuite.new:{ var name = 'AotParityBlockSpec' }).add:{
    .test:monomorphicIntBlockStaysExact -> {
        var data = #();
        var i = 0;
        { i < 200 }.whileDo:{ data.add:i; i = i + 1 };
        var out = data.collect:{ |x| (x * 3) + 1 };
        .is:{ out.at:0 } equalTo:1;
        .is:{ out.at:199 } equalTo:598;
        .is:{ out.count } equalTo:200
    };

    .test:kindChangeMidStreamBailsExactly -> {
        "* the same literal block goes hot on Integers, then receives Doubles
        "* and Strings - the speculated entry must Bail per element, never
        "* wrong-answer. String + Integer concatenates via +, so a block doing
        "* `x + x` is meaningful for every kind fed here.
        var mixed = #();
        var i = 0;
        { i < 50 }.whileDo:{ mixed.add:i; i = i + 1 };
        mixed.add:2.5;
        mixed.add:'ab';
        var out = mixed.collect:{ |x| x + x };
        .is:{ out.at:10 } equalTo:20;
        .is:{ out.at:50 } equalTo:5.0;
        .is:{ out.at:51 } equalTo:'abab'
    };

    .test:paramReassignmentInSpeculatedBlock -> {
        var data = #();
        var i = 0;
        { i < 100 }.whileDo:{ data.add:i; i = i + 1 };
        var out = data.collect:{ |x| x = x + 1; x * 2 };
        .is:{ out.at:0 } equalTo:2;
        .is:{ out.at:99 } equalTo:200
    };

    .test:routedDirectEachStaysExact -> {
        "* a hot literal-block each: site routes to the send path once the
        "* block compiles speculated (S2) - captured-local writes and a
        "* mid-stream kind change must stay exact through the rerouting.
        var data = #();
        var i = 0;
        { i < 40 }.whileDo:{ data.add:i; i = i + 1 };
        var sum = 0;
        var rounds = 0;
        { rounds < 30 }.whileDo:{ data.each:{ |x| sum = sum + x }; rounds = rounds + 1 };
        .is:{ sum } equalTo:23400;
        data.add:2.5;
        var tail = 0.0;
        data.each:{ |x| tail = tail + x };
        .is:{ tail } equalTo:782.5
    };

    .test:nilAmongIntsStaysExact -> {
        "* nil observes as Obj: a nil seen during the warmth window prevents
        "* speculation; one arriving after promotion Bails. Either way the
        "* answer matches the interpreter.
        var data = #();
        var i = 0;
        { i < 60 }.whileDo:{ data.add:i; i = i + 1 };
        data.add:nil;
        var out = data.collect:{ |x| x.defined?.if:{ x + 1 } else:{ -1 } };
        .is:{ out.at:5 } equalTo:6;
        .is:{ out.at:60 } equalTo:(-1)
    }
}
