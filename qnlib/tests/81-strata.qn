"* [Strata] ORM (quoin_packages/strata) — slice 1: model DSL + registry, lazy
"* relations, the block-predicate compiler, dialects, repo. The pure layers
"* (predicate compilation, SQL lowering) need no database at all — the adbc
"* extension loads lazily at first Repo construction — so those tests run
"* unconditionally. The end-to-end tests gate on the same two optional
"* install-time dependencies as 43-adbc.qn (extension binary + SQLite driver)
"* and report SKIPPED when either is missing.
use strata:*

[Strata]Model <- Widget <- {
    .table:'widgets';
    .col:#id type:Integer;
    .col:#name;
    .col:#kind;
    .col:#weightKg type:Double
}

"* Declaration defaults: no .table: -> lowercased name + 's'; col:as: override.
[Strata]Model <- Gadget <- {
    .col:#id;
    .col:#label as:'tag_text'
}

var strataReady = {
    Extension.loadPackage: 'quoin_packages/adbc';
    (([ADBC]Database.sqliteMemory.connect).query: 'select 1').toList;
    true
}.catch:{ false }

"* A fresh in-memory repo with the widgets table and three rows.
var freshRepo = {
    var repo = [Strata]Repo.sqliteMemory
    repo.execute:'create table widgets (id integer, name text, kind text, weight_kg real)'
    repo.execute:'insert into widgets values (?, ?, ?, ?)' params:#( 1 'Anvil' 'tool' 40.0 )
    repo.execute:'insert into widgets values (?, ?, ?, ?)' params:#( 2 'Axle' 'part' 3.5 )
    repo.execute:'insert into widgets values (?, ?, ?, ?)' params:#( 3 'Bolt' nil 0.1 )
    repo
}

(TestSuite.new:{ var name = 'Strata' }).add:{
    "* ---- pure: declaration + lowering (no database) ----
    .test:
    registryAndDefaults -> {
        .is:{ Widget.strataTable } equalTo:'widgets';
        .is:{ Widget.strataSqlCol:#weightKg } equalTo:'weight_kg';
        .is:{ Gadget.strataTable } equalTo:'gadgets';
        .is:{ Gadget.strataSqlCol:#label } equalTo:'tag_text';
        .does:{ Widget.strataSqlCol:#nope } throw:#/unknown column nope/;
    };

    .test:
    lowersThePlan -> {
        var lowered = (((Widget.where:{ |w| w.kind == 'gear' }).orderBy:#name).limit:2).toSql;
        .is:{ lowered.first } equalTo:'SELECT * FROM "widgets" WHERE ("kind" = ?) ORDER BY "name" LIMIT 2';
        .is:{ lowered.second } equalTo:#( 'gear' );

        var paged = ((((Widget.all.distinct).orderByDesc:#weightKg).limit:5).skip:10).toSql;
        .is:{ paged.first } equalTo:'SELECT DISTINCT * FROM "widgets" ORDER BY "weight_kg" DESC LIMIT 5 OFFSET 10';
    };

    .test:
    compilesPredicates -> {
        "* captures bind as parameters; && / ~ / arithmetic pass through
        var minW = 2.5;
        var lowered = (Widget.where:{ |w| w.weightKg > minW && (w.name ~ 'A%') }).toSql;
        .is:{ lowered.first } equalTo:'SELECT * FROM "widgets" WHERE (("weight_kg" > ?) AND ("name" LIKE ?))';
        .is:{ lowered.second } equalTo:#( 2.5 'A%' );

        "* a captured subtree evaluates host-side (minW * 2 is one parameter)
        .is:{ (Widget.where:{ |w| w.weightKg > (minW * 2) }).toSql.second } equalTo:#( 5.0 );

        "* nil tests, defined?, in:, between:and:, negation
        .is:{ (Widget.where:{ |w| w.kind == nil }).toSql.first } equalTo:'SELECT * FROM "widgets" WHERE ("kind" IS NULL)';
        .is:{ (Widget.where:{ |w| w.kind != nil }).toSql.first } equalTo:'SELECT * FROM "widgets" WHERE ("kind" IS NOT NULL)';
        .is:{ (Widget.where:{ |w| w.name.defined? }).toSql.first } equalTo:'SELECT * FROM "widgets" WHERE ("name" IS NOT NULL)';
        var ids = #( 1 2 3 );
        var inSql = (Widget.where:{ |w| w.id.in:ids }).toSql;
        .is:{ inSql.first } equalTo:'SELECT * FROM "widgets" WHERE ("id" IN (?, ?, ?))';
        .is:{ inSql.second } equalTo:#( 1 2 3 );
        var lo = 1;
        var hi = 9;
        .is:{ (Widget.where:{ |w| w.id.between:lo and:hi }).toSql.second } equalTo:#( 1 9 );
        .is:{ (Widget.where:{ |w| !(w.kind == 'x') }).toSql.first } equalTo:'SELECT * FROM "widgets" WHERE (NOT ("kind" = ?))';
    };

    .test:
    whereTiersCompose -> {
        "* Map tier: equality per pair (nil -> IS NULL); multiple wheres AND
        var lowered = ((Widget.where:#{ 'kind': 'tool' }).where:#{ 'name': nil }).toSql;
        .is:{ lowered.first } equalTo:'SELECT * FROM "widgets" WHERE ("kind" = ?) AND ("name" IS NULL)';
        .is:{ lowered.second } equalTo:#( 'tool' );

        "* raw tier: fragment + params pass straight through
        var raw = (Widget.where:'weight_kg > ? and kind = ?' params:#( 1.5 'tool' )).toSql;
        .is:{ raw.first } equalTo:'SELECT * FROM "widgets" WHERE (weight_kg > ? and kind = ?)';
        .is:{ raw.second } equalTo:#( 1.5 'tool' );
    };

    .test:
    buildTimeRefusals -> {
        .does:{ Widget.where:{ |w| w.nope == 1 } } throw:#/unknown column nope/;
        .does:{ Widget.where:{ |w x| w.id == x } } throw:#/exactly one row parameter/;
        .does:{ Widget.where:{ |w| w.id == @min } } throw:#/instance state/;
        .does:{ Widget.where:{ |w| w.id == (.min) } } throw:#/reference self/;
        .does:{ Widget.where:{ |w| w } } throw:#/not a value/;
        .does:{ Widget.where:{ |w| w.name.reverse == 'x' } } throw:#/not supported/;
        .does:{ Widget.where:{ |w| w.id == missingCapture } } throw:#/cannot evaluate/;
    };

    .test:
    postgresPlaceholders -> {
        var d = [Strata]PostgresDialect.new;
        .is:{ d.placeholders:'a = ? AND b IN (?, ?)' } equalTo:'a = $1 AND b IN ($2, $3)';
        .is:{ d.placeholders:'no params' } equalTo:'no params';
        .is:{ [Strata]SqliteDialect.new.placeholders:'a = ?' } equalTo:'a = ?';
    };

    .test:
    missingDefaultRepoRefuses -> {
        [Strata]State.at:'defaultRepo' put:nil;
        .does:{ (Widget.where:#{ 'kind': 'tool' }).toList } throw:#/no default repo/;
    };
}

"* End-to-end tier as its OWN suite: skip: marks a whole suite skipped, and
"* the pure tier above must run even where the extension isn't installed.
(TestSuite.new:{ var name = 'Strata e2e' }).add:{
    strataReady.if:{
        .test:
        forcesHydratesAndMemoizes -> {
            [Strata]Repo.default:freshRepo.value;
            var rel = (Widget.where:{ |w| w.weightKg > 1.0 }).orderBy:#name;
            var rows = rel.toList;
            .is:{ rows.count } equalTo:2;
            .is:{ rows.first.class.name } equalTo:'Widget';
            "* generated accessors over @row, and the generic at:
            .is:{ rows.first.name } equalTo:'Anvil';
            .is:{ rows.second.name } equalTo:'Axle';
            .is:{ rows.first.at:#weightKg } equalTo:40.0;
            "* memoized: a second force reuses the cache (same instances)
            .isTrue:{ rel.toList.first == rows.first };
            "* hydration tagged the cohort for slice-2 batching
            .is:{ rows.first.strataBatch.count } equalTo:2;
        };

        .test:
        forcePointsQueryTheRepo -> {
            [Strata]Repo.default:freshRepo.value;
            var caught = 'A%';
            .is:{ (Widget.where:{ |w| w.name ~ caught }).count } equalTo:2;
            .is:{ Widget.all.count } equalTo:3;
            .is:{ (Widget.orderBy:#weightKg).first.name } equalTo:'Bolt';
            .isTrue:{ (Widget.where:#{ 'kind': 'tool' }).exists? };
            .isFalse:{ (Widget.where:#{ 'kind': 'gear' }).exists? };
            .is:{ (Widget.orderBy:#name).pluck:#name } equalTo:#( 'Anvil' 'Axle' 'Bolt' );
            .is:{ (Widget.where:#{ 'kind': nil }).pluck:#name } equalTo:#( 'Bolt' );
        };

        .test:
        viaRoutesAroundTheDefault -> {
            [Strata]State.at:'defaultRepo' put:nil;
            var repo = freshRepo.value;
            .is:{ ((Widget.where:'kind = ?' params:#( 'part' )).via:repo).pluck:#name } equalTo:#( 'Axle' );
            "* the default stays unset — routing never leaked into module state
            .does:{ Widget.all.toList } throw:#/no default repo/;
        };

        .test:
        forceTimeErrorsCarryTheSql -> {
            [Strata]Repo.default:freshRepo.value;
            var failed = nil;
            { (Widget.where:'no_such_column = ?' params:#( 1 )).toList }.catch:{ |e| failed = e };
            .isTrue:{ [Strata]Error ~ failed };
            .does:{ #/no_such_column/ } match:(failed.sql);
        };
    }
    else:{
        .skip: 'adbc extension binary or SQLite driver not installed (build crates/adbc + install the ADBC SQLite driver to run the e2e tier)';
    };
}
