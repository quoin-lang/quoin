"* Statistics helpers on the Iterate mixin (qnlib/core/07-statistics.qn). Exact equalTo for
"* values that are exact (integer-valued means, selected elements, nil/empty); closeTo for the
"* sqrt/division results.

(TestSuite.new:{ var name = 'Statistics' }).add:{
    .test:
    mean -> {
        .is:{ #(1 2 3 4).mean } equalTo:2.5;
        .is:{ #(2 4 6).mean } equalTo:4.0;
        .is:{ #(1 2).mean } a:Double;          "* integer inputs -> Double, no truncation
        .is:{ #(5).mean } equalTo:5.0;
        .is:{ #().mean } equalTo:nil;
    };

    .test:
    median -> {
        .is:{ #(1 2 3).median } equalTo:2;     "* odd -> exact middle element
        .is:{ #(3 1 2).median } equalTo:2;     "* sorts first
        .is:{ #(1 2 3 4).median } equalTo:2.5; "* even -> average (Double)
        .is:{ #(1 2 3 4).median } a:Double;
        .is:{ #(7).median } equalTo:7;
        .is:{ #().median } equalTo:nil;
    };

    .test:
    variance -> {
        "* sample variance of 2,4,6: mean 4, squared devs 4+0+4=8, / (3-1) = 4
        .is:{ #(2 4 6).variance } closeTo:4.0;
        .is:{ #(2 4 6).populationVariance } closeTo:(8.0 / 3);
        .is:{ #(5).variance } equalTo:nil;     "* n<2 undefined
        .is:{ #().variance } equalTo:nil;
        .is:{ #().populationVariance } equalTo:nil;
    };

    .test:
    stddev -> {
        .is:{ #(2 4 6).stddev } closeTo:2.0;   "* sqrt(4)
        .is:{ #(2 4 6).populationStddev } closeTo:((8.0 / 3).sqrt);
        .is:{ #(5).stddev } equalTo:nil;
        .is:{ #().stddev } equalTo:nil;
    };

    .test:
    percentile -> {
        var data = #(1 2 3 4 5);
        .is:{ data.percentile:0 } equalTo:1;     "* min
        .is:{ data.percentile:100 } equalTo:5;   "* max
        .is:{ data.percentile:50 } closeTo:3.0;  "* == median
        .is:{ data.percentile:25 } closeTo:2.0;  "* rank 1.0 -> element 2
        "* interpolation: 50th pct of 1..4 -> rank 1.5 -> 2 + 0.5*(3-2) = 2.5
        .is:{ #(1 2 3 4).percentile:50 } closeTo:2.5;
        .is:{ #().percentile:50 } equalTo:nil;
        .does:{ data.percentile:(0-1) } throw:ValueError;
        .does:{ data.percentile:101 } throw:ValueError;
    };

    .test:
    mode -> {
        .is:{ #(1 2 2 3 3 3).mode } equalTo:3;
        .is:{ #(4 4 5 5).mode } equalTo:4;       "* tie -> first encountered
        .is:{ #('a' 'b' 'b').mode } equalTo:'b';
        .is:{ #().mode } equalTo:nil;
    };

    .test:
    modes -> {
        .is:{ #(1 2 2 3 3 3).modes } equalTo:#(3);
        .is:{ #(4 4 5 5).modes } equalTo:#(4 5); "* multimodal, first-encountered order
        .is:{ #().modes } equalTo:#();
    };
}
