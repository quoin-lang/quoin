(TestSuite.new:{ var name = 'Sets' }).add:{
    .test:
    literalAndCount -> {
        .is:{ #<1 2 3 2 1>.count } equalTo:3;     "* literal dedups by ==:
        .is:{ #<>.count } equalTo:0;
    };

    .test:
    membership -> {
        .is:{ #<1 2 3>.contains?:2 } equalTo:true;
        .is:{ #<1 2 3>.contains?:9 } equalTo:false;
    };

    .test:
    addAndRemove -> {
        .is:{
            var s = #<1 2>;
            s.add:3;
            s.add:2;                              "* duplicate ignored
            s.count
        } equalTo:3;
        .is:{
            var s = #<1 2 3>;
            s.remove:2;
            s.contains?:2
        } equalTo:false;
    };

    .test:
    equalityIsOrderIndependent -> {
        .is:{ #<1 2 3> == #<3 2 1> } equalTo:true;
        .is:{ #<1 2> == #<1 2 3> } equalTo:false;
    };

    .test:
    algebra -> {
        .is:{ #<1 2>.union:#<2 3> } equalTo:#<1 2 3>;
        .is:{ #<1 2 3>.intersection:#<2 4> } equalTo:#<2>;
        .is:{ #<1 2 3>.difference:#<2> } equalTo:#<1 3>;
        .is:{ #<1 2>.subset?:#<1 2 3> } equalTo:true;
        .is:{ #<1 2 3>.superset?:#<1 2> } equalTo:true;
    };

    .test:
    iterateCombinators -> {
        .is:{ #<1 2 3>.collect:{ |x| x * 10 } } equalTo:#( 10 20 30 );
        .is:{ (#<1 2 3 4>.select:{ |x| x > 2 }).list } equalTo:#( 3 4 );
    };

    .test:
    literalInMessagePosition -> {
        "* The grammar fix: a set literal can be the direct receiver of a message,
        "* and `>` inside an element must be parenthesized (a bare `>` closes the set).
        .is:{ #<1 2 3>.count } equalTo:3;
        .is:{ #<(2 > 1)  5>.count } equalTo:2;
    };

    .test:
    eachVisitsEveryElement -> {
        var seen = #();
        #<1 2 3>.each:{ |x| seen.add:x };
        .is:{ seen.count } equalTo:3;
        .isTrue:{ seen.contains?:2 };
    };

    .test:
    stringForm -> {
        .is:{ #<1 2 3>.s } equalTo:'#<1 2 3>';
        .is:{ #<>.s } equalTo:'#<>';
    };

    .test:
    equalityEdges -> {
        .isFalse:{ #<1 2> == 5 };          "* rhs is not a Set
        .isFalse:{ #<1 2> == #<1 9> };     "* same size, differing element
    };
}
