(TestSuite.new:{ name = 'Misc' }).add:{
    .test:
    humanizeDuration -> {
        "* Reporter renders elapsed µs in the largest unit >= 1, one decimal for ms/s."
        r = AnsiTestReporter.new:{ out = nil };
        .is:{ r.humanize:0 } equalTo:'0µs';
        .is:{ r.humanize:524 } equalTo:'524µs';
        .is:{ r.humanize:999 } equalTo:'999µs';
        .is:{ r.humanize:1000 } equalTo:'1.0ms';
        .is:{ r.humanize:12524 } equalTo:'12.5ms';
        .is:{ r.humanize:999999 } equalTo:'999.9ms';
        .is:{ r.humanize:1000000 } equalTo:'1.0s';
        .is:{ r.humanize:1500000 } equalTo:'1.5s';
    };

    .test:
    defaultNotEq -> {
        .is:{
            EqTester1 <- {
                #'==:' --> { true }
            }
            x = EqTester1.new
            #( (x==x) (x!=x) )
        } equalTo:#( true false );

        .is:{
            EqTester2 <- {
                #'==:' --> { false }
            }
            x = EqTester2.new
            #( (x==x) (x!=x) )
        } equalTo:#( false true );
    };

    .test:
    whileDo -> {
        .is:{
            i = 3;
            r = #();
            { i < 10 }.whileDo:{ r.add:i; i = i + 1 }
            ^r
        } equalTo:#( 3 4 5 6 7 8 9 );
    };

    .test:
    blockRecursion -> {
        .is:{
            block = {|a|
            (a >= 'aaaaa').if:{ a }
                         else:{ block.value:(a + 'a') };
            };
            block.value:'a'
        } equalTo:'aaaaa';
    };

    .test:
    constOperator -> {
        .is:{ TestConst <- 456; TestConst } equalTo:456;
        .is:{ [Y]TestConst <- 789; [Y]TestConst } equalTo:789;
        .does:{ TestConst <- 123 } throw:'Global [/]TestConst is already defined in this scope';
        .does:{ [Y]TestConst <- 123 } throw:'Global [Y]TestConst is already defined in this scope';
        .does:{ TestConst = 123 } throw:'Can\'t modify global constant [/]TestConst';
    };

    .test:
    throw3 -> {
        .does:{ !!! } throw:'!!!';
        .does:{ ??? } throw:'???';
        .does:{ ... } throw:'...';
    };

    .test:
    immutableReservedIdentifiers -> {
        .does:{ true = false } throw:'Can\'t modify reserved identifier true';
        .does:{ false = true } throw:'Can\'t modify reserved identifier false';
        .does:{ nil = 1 } throw:'Can\'t modify reserved identifier nil';
    };

    .test:
    assignGlobal -> {
        .is:{ [Y]Mutable = 1; [Y]Mutable } equalTo:1;
        .is:{ [/]Mutable = 2; [/]Mutable } equalTo:2;
    };

    .test:
    assignIgnore -> {
        .is:{ _ = 42; } equalTo:42;
        .is:{ *_ = 42; } equalTo:42;
    };

    .test:
    testDefined -> {
        .isFalse:{ nil.defined? };
        .isTrue:{ 0.defined? };
    };

    .test:
    nilsPrintEmpty -> {
        .is:{ nil.s } equalTo:'';
    };

    .test:
    nilsPropagate -> {
        .is:{ nil + 42 } equalTo:nil;
        .is:{ nil - 42 } equalTo:nil;
        .is:{ nil * 42 } equalTo:nil;
        .is:{ nil / 42 } equalTo:nil;
        .is:{ nil % 42 } equalTo:nil;
    };

    .test:
    ansiEscapesInterpolatedValues -> {
        "* `String#ansiEscaped` doubles '$' so a value can't inject color codes.
        .is:{ '$foo'.ansiEscaped } equalTo:'$$foo';
        .is:{ 'plain'.ansiEscaped } equalTo:'plain';
        "* ANSI's `%` escapes a non-ANSI argument's '$' in the underlying string,
        "* so an arbitrary value (e.g. a test-failure value) can't corrupt the
        "* color template or inject markup.
        .is:{ (#ANSI'v=%' % '$x').string } equalTo:'v=$$x';
        "* ...but a nested ANSI argument is left alone, so its markup still renders.
        .is:{ (#ANSI'v=%' % #ANSI'$#bw[hi$]').string.contains?:'$#bw[hi$]' } equalTo:true;
    };

    .test:
    evalSelf -> {
        "* `Runtime.eval:self:` binds the receiver as the eval'd code's `self`, so `self`,
        "* `@ivars`, and `self.method` all resolve. Plain `eval:` keeps top-level `self` nil.
        EvalSelfProbe <- { |@total|
            init -> { @total = 7 }
            double -> { @total * 2 }
        };
        b = EvalSelfProbe.new;
        .is:{ Runtime.eval:'self' self:b } equalTo:b;
        .is:{ Runtime.eval:'@total' self:b } equalTo:7;
        .is:{ Runtime.eval:'@total + 1' self:b } equalTo:8;
        .is:{ Runtime.eval:'self.double' self:b } equalTo:14;
        "* no receiver → top-level `self` is nil (unchanged)
        .is:{ Runtime.eval:'self' } equalTo:nil;
    };

    .test:
    evalBindings -> {
        "* `Runtime.eval:bindings:` seeds the map's entries as locals in the eval'd frame, so
        "* the expression can reference them by name.
        .is:{ Runtime.eval:'x + y' bindings:#{ 'x': 3 'y': 4 } } equalTo:7;
        .is:{ Runtime.eval:'x * x' bindings:#{ 'x': 6 } } equalTo:36;
        "* a binding shadows a same-named global
        EvalBindShadow <- 99;
        .is:{ Runtime.eval:'EvalBindShadow' bindings:#{ 'EvalBindShadow': 7 } } equalTo:7;
        "* empty bindings still evaluates globals/literals
        .is:{ Runtime.eval:'1 + 2' bindings:#{} } equalTo:3;
    };

    .test:
    classDefaults -> {
        "* `default` is the class-side fallback a typed field gets when unset
        .is:{ Integer.default } equalTo:0;
        .is:{ Double.default } equalTo:0.0;
        .is:{ String.default } equalTo:'';
        .is:{ Map.default } equalTo:#{};
        .is:{ List.default } equalTo:#();
        .is:{ Set.default } equalTo:#<>;
        .is:{ Nil.default } equalTo:nil;
        .is:{ ANSI.default.length } equalTo:0;   "* the empty ANSI string
    };

    .test:
    assertionMatchers -> {
        "* exercise two test-DSL matchers that no other suite happens to use
        .is:{ 5 } an:Integer;
        .elementsOf:{ #( 3 1 2 ) } areEqualTo:#( 1 2 3 );
    };
}
