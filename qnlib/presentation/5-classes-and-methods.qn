Person <- { |@name @age|
    init: -> { |name age|
        @name = name;
        @age = age
    };

    name -> { @name };
    age -> { @age };

    s --> { %'%{@name}, %{@age} years old' }
};

var damonPerson = Person.new:{
    var name = 'Damon';
    var age = 39  "* Narrator: He's not 39
};

damonEmployee.s.print
