"* Test entry point. Pulls in the framework and every test file via `use`; each suite
"* self-registers into [Test]Suites (see test.qn), which we then run. `use std:tests/*`
"* loads qnlib/tests/*.qn in UTF-8 sorted order (== numeric, since prefixes are padded).
use test;
use std:tests/*;

runner = TestRunner.new;
[Test]Suites.each:{ |s| runner.add:s };

results = runner.run:AnsiTestReporter.new:{ out = [IO]Stdout };

results.none?:{ |tr| tr.failures.any? }
