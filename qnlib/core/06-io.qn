[IO]Stdout <- ([IO]Handle.stdout);
[IO]Stderr <- ([IO]Handle.stderr);

[IO]Folder <-- {
    .mix:Iterate;

    "* Folder is a native directory stream; drive its native cursor to satisfy
    "* the each:-based Iterate protocol.
    each: -> { |b|
        { .next }.whileDefinedDo:{ |e| b.valueWithSelfOrArg:e };
        .reset
    }
}
